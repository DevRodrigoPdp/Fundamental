---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const products = [
  {
    category: 'FRENOS',
    name: 'Disco GT 160',
    description: 'Disco de acero galvanizado ventilado, para bujes de 6 tornillos.',
    ref: 'T3R-DISCO-GT-160',
  },
  {
    category: 'FRENOS',
    name: 'Pastillas SRAM Guide',
    description: 'Pastillas de freno de resina para SRAM Guide.',
    ref: 'T3R-PAST-SRAM-GDE',
  },
  {
    category: 'TRANSMISIÓN',
    name: 'Plato SRAM Direct Mount 32T',
    description: 'Plato de aluminio, sistema Direct Mount SRAM, 11-12v.',
    ref: 'T3R-PLATO-SRAM-32',
  },
  {
    category: 'PEDALES',
    name: 'Pedal XCO Automático',
    description: 'Pedal automático de montaña, cuerpo de fibra, cala SPD.',
    ref: 'T3R-PED-XCO',
  },
  {
    category: 'MANILLAR',
    name: 'Puño Triángulos',
    description: 'Puño ergonómico negro, 2 arandelas, máximo confort.',
    ref: 'T3R-PUNO-TRIA',
  },
  {
    category: 'ILUMINACIÓN',
    name: 'Luz Delantera 400 Lúmenes',
    description: 'Luz LED delantera, 400 lúmenes, carga USB-C.',
    ref: 'T3R-LUZ-DEL-400',
  },
];
---

<Layout title="Fundamental">

  <!-- NAV -->
  <header class="flex items-center justify-between px-16 py-6 bg-white">
    <a href="/" class="font-display uppercase text-xl tracking-[-0.03em]" style="font-weight: 600;" transition:name="nav-logo">Fundamental Bike Parts</a>
    <nav class="flex gap-10">
      <a href="/marcas" class="text-base text-[#333] hover:text-black transition-colors">Marcas</a>
      <a href="/nosotros" class="text-base text-[#333] hover:text-black transition-colors">Nosotros</a>
      <a href="/contacto" class="text-base text-[#333] hover:text-black transition-colors">Contacto</a>
    </nav>
  </header>

  <!-- HERO -->
  <section class="relative h-[88vh] bg-[#1A100C] flex items-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-[#1A100C] via-[#1A100C]/70 to-[#1A100C]/10 z-10"></div>
    <div class="absolute right-0 top-0 bottom-0 w-[60%] bg-gradient-to-l from-[#3D2010] to-[#1A100C]"></div>

    <div class="relative z-20 px-16 max-w-2xl">
      <p class="text-sm text-gray-400 tracking-[0.3em] uppercase mb-6">T3R · The Three Riders</p>
      <h1 class="text-[82px] font-bold leading-[1.0] mb-6">
        <span class="text-white">Componentes</span><br />
        <span class="text-[#C4A072]">fundamentales.</span>
      </h1>
      <p class="text-gray-300 text-base leading-relaxed max-w-[320px] mb-10">
        Una nueva marca de componentes profesionales de ciclismo, diseñada para quienes ruedan en serio. Minimal, preciso, duradero.
      </p>
      <a
        href="#esenciales"
        class="inline-block border border-white/70 text-white text-base px-7 py-3.5 hover:bg-white hover:text-black transition-colors"
      >
        Explorar catálogo
      </a>
    </div>
  </section>

  <!-- PRODUCTOS DESTACADOS -->
  <section id="esenciales" class="py-24 px-16">
    <div class="flex items-start justify-between mb-14">
      <div>
        <p class="text-xs text-gray-400 tracking-[0.25em] uppercase mb-4">Destacados T3R</p>
        <h2 class="text-[56px] font-bold leading-tight">Los esenciales.</h2>
        <p class="text-base text-gray-500 mt-4 max-w-[300px] leading-relaxed">
          Selección de referencias T3R disponibles bajo solicitud. Precisión, durabilidad y diseño minimal.
        </p>
      </div>
      <a
        href="/catalogo"
        class="border border-black text-base px-6 py-2.5 mt-4 hover:bg-black hover:text-white transition-colors"
      >
        Ver todo el catálogo
      </a>
    </div>

    <div class="grid grid-cols-3 gap-x-8 gap-y-14">
      {products.map((p) => (
        <div class="group cursor-pointer">
          <div class="bg-[#E8B49A] aspect-square mb-5 w-full overflow-hidden">
            <div class="w-full h-full transition-transform duration-300 group-hover:scale-[1.03] bg-[#E8B49A]"></div>
          </div>
          <p class="text-xs text-gray-400 tracking-[0.25em] uppercase mb-1.5">{p.category}</p>
          <h3 class="font-semibold text-lg mb-1.5">{p.name}</h3>
          <p class="text-sm text-gray-500 leading-relaxed mb-2">{p.description}</p>
          <p class="text-sm text-gray-400 mb-0">{p.ref}</p>
          <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-100">
            <p class="text-sm text-gray-400">Consulta disponibilidad</p>
            <a href="/contacto" class="text-sm font-medium inline-flex items-center gap-1">
              Solicitar
              <span class="inline-block transition-transform duration-200 group-hover:translate-x-1">→</span>
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="bg-[#F0EDE8] py-20 px-16">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-xs text-gray-400 tracking-[0.25em] uppercase mb-4">Newsletter</p>
        <h2 class="text-[44px] font-bold leading-tight mb-3">Mantente informado.</h2>
        <p class="text-base text-gray-500 max-w-[280px] leading-relaxed">
          Lanzamientos, novedades de catálogo y notas técnicas. Sin ruido.
        </p>
      </div>
      <form class="flex gap-0">
        <input
          type="email"
          placeholder="tu@email.com"
          class="border border-gray-300 bg-white px-5 py-3.5 text-base w-72 outline-none focus:border-black transition-colors"
        />
        <button
          type="submit"
          class="bg-black text-white text-base px-7 py-3.5 hover:bg-[#222] transition-colors"
        >
          Suscribirme
        </button>
      </form>
    </div>
  </section>

  <!-- CTA CATÁLOGO -->
  <section class="py-32 px-16 text-center">
    <p class="text-xs text-gray-400 tracking-[0.25em] uppercase mb-6">Catálogo completo</p>
    <h2 class="text-[58px] font-bold max-w-[620px] mx-auto leading-[1.1] mb-6">
      Más de 60 referencias disponibles bajo solicitud.
    </h2>
    <p class="text-base text-gray-500 max-w-[420px] mx-auto leading-relaxed mb-12">
      Explora la gama completa T3R: frenos, transmisión, ruedas, cockpit, pedales e iluminación. Solicita la referencia que necesites y te respondemos con disponibilidad y plazo.
    </p>
    <a
      href="/catalogo"
      class="inline-block bg-black text-white text-base px-10 py-4 hover:bg-[#222] transition-colors"
    >
      Ver catálogo T3R
    </a>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-gray-100 px-16 py-10 flex items-start justify-between">
    <div>
      <p class="text-base font-bold mb-2">T3R Fundamental</p>
      <p class="text-sm text-gray-400 max-w-[240px] leading-relaxed">
        Distribuidora de componentes profesionales para ciclismo. Madrid, España.
      </p>
    </div>
    <p class="text-sm text-gray-400">© 2026 FUNDAMENTAL</p>
  </footer>

</Layout>
