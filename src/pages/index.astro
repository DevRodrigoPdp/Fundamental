---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { supabase } from '../lib/supabase';

const { data: products, error } = await supabase
  .from('productos_t3r')
  .select('nombre, categoria, descripcion_corta, sku')
  .eq('activo', true)
  .in('sku', [
    'T3R-DISCO-6T-160',
    'T3R-PAST-SRAM-GDE',
    'T3R-PED-XCO',
    'T3R-PED-EBIKE',
    'T3R-VLV-ELITE-42',
    'T3R-EJE-BSA-SH',
  ]);

if (error) console.error('Supabase productos error:', error.message);

const skus = (products ?? []).map((p: any) => p.sku);

const { data: imagenes, error: imgError } = await supabase
  .from('imagenes_productos')
  .select('producto_sku, url, orden')
  .in('producto_sku', skus)
  .eq('orden', 1);

if (imgError) console.error('Supabase imagenes error:', imgError.message);


const imgMap: Record<string, string> = {};
(imagenes ?? []).forEach((i: any) => { imgMap[i.producto_sku] = i.url; });

const formatted = (products ?? []).map((p: any) => ({
  category: p.categoria.toUpperCase(),
  name: p.nombre,
  description: p.descripcion_corta,
  ref: p.sku,
  imagen: imgMap[p.sku] ?? null,
}));
---

<Layout title="Fundamental">

  <!-- NAV -->
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-16 py-6 bg-[#1A100C]/80 backdrop-blur-md">
    <a href="/" class="font-display uppercase text-xl tracking-[-0.03em] text-white" style="font-weight: 600;" transition:name="nav-logo">Fundamental Bike Parts</a>
    <nav class="flex gap-10">
      <a href="/marcas" class="text-base text-white/70 hover:text-white transition-colors">Marcas</a>
      <a href="/nosotros" class="text-base text-white/70 hover:text-white transition-colors">Nosotros</a>
      <a href="/contacto" class="text-base text-white/70 hover:text-white transition-colors">Contacto</a>
    </nav>
  </header>

  <!-- HERO -->
  <section class="relative h-screen bg-[#1A100C] flex flex-col justify-end overflow-hidden">
    <!-- Foto fondo -->
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/catalogo_t3r/combos/combos_9.jpg');"></div>
    <!-- Gradiente cinematic: oscuro desde abajo, transparente arriba -->
    <div class="absolute inset-0 z-10" style="background: linear-gradient(to top, #1A100C 0%, rgba(26,16,12,0.75) 40%, rgba(26,16,12,0.2) 100%);"></div>

    <!-- Contenido bottom-left editorial -->
    <div class="relative z-20 px-16 pb-16 w-full">
      <div class="flex items-center gap-3 mb-6 hero-tag">
        <div class="w-8 h-px bg-[#C4A072]"></div>
        <p class="text-xs text-[#C4A072] tracking-[0.35em] uppercase">T3R · The Three Riders</p>
      </div>
      <h1 class="text-[96px] font-bold leading-[0.88] mb-10 hero-heading" style="text-shadow: 0 4px 40px rgba(0,0,0,0.6);">
        <span class="block text-white">Componentes</span>
        <span class="block text-[#C4A072]">fundamentales.</span>
      </h1>
      <div class="flex items-center gap-8 hero-cta">
        <a
          href="#esenciales"
          class="bg-[#C4A072] text-[#1A100C] text-sm font-semibold px-8 py-4 hover:bg-[#D4B280] transition-colors tracking-[0.08em] uppercase cursor-pointer"
        >
          Explorar catálogo
        </a>
        <a href="/marcas" class="text-white/60 text-sm tracking-[0.08em] uppercase hover:text-white transition-colors flex items-center gap-2 cursor-pointer">
          Nuestras marcas
          <span class="inline-block transition-transform duration-200 group-hover:translate-x-1">→</span>
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 right-16 z-20 flex flex-col items-center gap-2">
      <span class="text-[10px] text-white/30 tracking-[0.25em] uppercase" style="writing-mode: vertical-rl;">Scroll</span>
      <div class="w-px h-10 bg-white/20 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full bg-white/70 hero-scroll-line"></div>
      </div>
    </div>
  </section>

  <!-- PRODUCTOS DESTACADOS -->
  <section id="esenciales" class="py-24 px-16">
    <div class="flex items-start justify-between mb-14">
      <div>
        <img src="/logo_t3r.png" alt="T3R" class="h-7 w-auto mb-4" />
        <h2 class="text-[56px] font-bold leading-tight">Los esenciales.</h2>
        <p class="text-base text-gray-500 mt-4 max-w-[300px] leading-relaxed">
          Selección de referencias T3R disponibles bajo solicitud. Precisión, durabilidad y diseño minimal.
        </p>
      </div>
      <a
        href="/catalogo"
        class="border border-black text-base px-6 py-2.5 mt-4 hover:bg-black hover:text-white transition-colors"
      >
        Ver todo el catálogo
      </a>
    </div>

    <div class="grid grid-cols-3 gap-x-8 gap-y-14">
      {formatted.map((p) => (
        <div class="group cursor-pointer">
          <div class="aspect-square mb-5 w-full overflow-hidden bg-[#F0EDE8]">
            {p.imagen ? (
              <img
                src={`/${p.imagen}`}
                alt={p.name}
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
                loading="lazy"
              />
            ) : (
              <div class="w-full h-full bg-[#E8B49A]"></div>
            )}
          </div>
          <p class="text-xs text-gray-400 tracking-[0.25em] uppercase mb-1.5">{p.category}</p>
          <h3 class="font-semibold text-lg mb-1.5">{p.name}</h3>
          <p class="text-sm text-gray-500 leading-relaxed mb-2">{p.description}</p>
          <p class="text-sm text-gray-400 mb-0">{p.ref}</p>
          <div class="flex items-center justify-between mt-3 pt-3 border-t border-gray-100">
            <p class="text-sm text-gray-400">Consulta disponibilidad</p>
            <a href="/contacto" class="text-sm font-medium inline-flex items-center gap-1">
              Solicitar
              <span class="inline-block transition-transform duration-200 group-hover:translate-x-1">→</span>
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="bg-[#F0EDE8] py-20 px-16">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-xs text-gray-400 tracking-[0.25em] uppercase mb-4">Newsletter</p>
        <h2 class="text-[44px] font-bold leading-tight mb-3">Mantente informado.</h2>
        <p class="text-base text-gray-500 max-w-[280px] leading-relaxed">
          Lanzamientos, novedades de catálogo y notas técnicas. Sin ruido.
        </p>
      </div>
      <form class="flex gap-0">
        <input
          type="email"
          placeholder="tu@email.com"
          class="border border-gray-300 bg-white px-5 py-3.5 text-base w-72 outline-none focus:border-black transition-colors"
        />
        <button
          type="submit"
          class="bg-black text-white text-base px-7 py-3.5 hover:bg-[#222] transition-colors"
        >
          Suscribirme
        </button>
      </form>
    </div>
  </section>

  <!-- CTA CATÁLOGO -->
  <section class="py-32 px-16 text-center">
    <p class="text-xs text-gray-400 tracking-[0.25em] uppercase mb-6">Catálogo completo</p>
    <h2 class="text-[58px] font-bold max-w-[620px] mx-auto leading-[1.1] mb-6">
      Más de 60 referencias disponibles bajo solicitud.
    </h2>
    <p class="text-base text-gray-500 max-w-[420px] mx-auto leading-relaxed mb-12">
      Explora la gama completa T3R: frenos, transmisión, ruedas, cockpit, pedales e iluminación. Solicita la referencia que necesites y te respondemos con disponibilidad y plazo.
    </p>
    <a
      href="/catalogo"
      class="inline-block bg-black text-white text-base px-10 py-4 hover:bg-[#222] transition-colors"
    >
      Ver catálogo T3R
    </a>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-gray-100 px-16 py-10 flex items-start justify-between">
    <div>
      <p class="text-base font-bold mb-2">T3R Fundamental</p>
      <p class="text-sm text-gray-400 max-w-[240px] leading-relaxed">
        Distribuidora de componentes profesionales para ciclismo. Madrid, España.
      </p>
    </div>
    <p class="text-sm text-gray-400">© 2026 FUNDAMENTAL</p>
  </footer>

</Layout>
