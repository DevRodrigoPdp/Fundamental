---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import '../styles/global.css';
import { supabase } from '../lib/supabase';

// Sitio estático (sin adapter/output:'server' en astro.config): esta query
// corre una sola vez en build, no en cada visita. Mantenerla aquí (SSR/build-time)
// en vez de fetch client-side es mejor para SEO: el HTML generado ya lleva
// los productos, indexable por Google y visible en previews de redes sociales.
const { data: products, error } = await supabase
  .from('productos_t3r')
  .select('nombre, categoria, descripcion_corta, sku')
  .eq('activo', true)
  .limit(8);

if (error) console.error('Supabase productos error:', error.message);

const skus = (products ?? []).map((p: any) => p.sku);

const { data: imagenes, error: imgError } = await supabase
  .from('imagenes_productos')
  .select('producto_sku, url, orden')
  .in('producto_sku', skus)
  .eq('orden', 1);

if (imgError) console.error('Supabase imagenes error:', imgError.message);

const imgMap: Record<string, string> = {};
(imagenes ?? []).forEach((i: any) => { imgMap[i.producto_sku] = i.url; });

const novedades = (products ?? []).map((p: any) => ({
  category: p.categoria,
  name: p.nombre,
  ref: p.sku,
  imagen: imgMap[p.sku] ? `/${imgMap[p.sku]}` : null,
}));
---

<Layout title="Fundamental Bike Parts — Distribuidora T3R · Whipp-Off · Transfer">

  <style is:global>
    html { scroll-behavior: smooth; }
    [data-reveal] {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    [data-reveal].visible { opacity: 1; transform: translateY(0); }
    [data-delay="1"] { transition-delay: 0.08s; }
    [data-delay="2"] { transition-delay: 0.16s; }

    .paint-fill-button {
      --paint-fill: white;
      --paint-text: #1A100C;
      --paint-border: white;
      position: relative;
      isolation: isolate;
      overflow: hidden;
      transition: border-color 0.35s ease, color 0.35s ease;
    }

    .paint-fill-button--dark {
      --paint-fill: #1A100C;
      --paint-text: white;
      --paint-border: #1A100C;
    }

    .paint-fill-button::before {
      content: '';
      position: absolute;
      left: -18%;
      top: 0;
      z-index: 0;
      width: 136%;
      height: 135%;
      background: var(--paint-fill);
      border-radius: 0 0 48% 52%;
      transform: translateY(-112%) rotate(-3deg);
      transition: transform 0.58s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .paint-fill-button::after {
      content: '';
      position: absolute;
      left: 12%;
      top: 0;
      z-index: 0;
      width: 38%;
      height: 60%;
      background: var(--paint-fill);
      border-radius: 999px;
      opacity: 0.9;
      transform: translateY(-140%) scale(0.92);
      transition: transform 0.64s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .paint-fill-button:hover,
    .paint-fill-button:focus-visible {
      color: var(--paint-text);
      border-color: var(--paint-border);
    }

    .paint-fill-button:hover::before,
    .paint-fill-button:focus-visible::before {
      transform: translateY(-5%) rotate(0deg);
    }

    .paint-fill-button:hover::after,
    .paint-fill-button:focus-visible::after {
      transform: translateY(35%) scale(1.1);
    }
  </style>

  <Nav />

  <!-- ═══ HERO — T3R ═══ -->
  <section class="relative h-screen overflow-hidden bg-[#1A100C]">
    <img
      src="/catalogo_t3r/combos/combos_9.jpg"
      alt="T3R componentes"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to top, #1A100C 0%, rgba(26,16,12,0.75) 40%, rgba(26,16,12,0.2) 100%);"></div>

    <div class="absolute inset-0 flex flex-col justify-end px-5 md:px-12 pb-16 z-10">
      <div class="flex items-center gap-3 mb-5">
        <div class="w-6 h-px bg-[#C4A072]"></div>
        <p class="text-[10px] text-[#C4A072] tracking-[0.4em] uppercase">T3R · The Three Riders</p>
      </div>
      <h1 class="text-[44px] sm:text-[60px] md:text-[90px] font-bold leading-[0.92] md:leading-[0.88] tracking-tight mb-8">
        <span class="block text-white">Componentes</span>
        <span class="block text-[#C4A072]">fundamentales.</span>
      </h1>
      <div class="flex items-center gap-3 md:gap-4">
        <a href="#productos"
          class="bg-[#C4A072] text-[#1A100C] text-xs font-bold px-6 md:px-9 py-3.5 md:py-4 hover:bg-[#D4B280] transition-colors tracking-[0.12em] uppercase cursor-pointer">
          Ver productos
        </a>
        <a href="/t3r"
          class="paint-fill-button border border-white/25 text-white/70 text-xs px-5 md:px-8 py-3.5 md:py-4 tracking-[0.1em] uppercase cursor-pointer">
          <span class="relative z-10">Conocer T3R</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ NOVEDADES T3R — carousel ═══ -->
  <section id="productos" class="bg-white px-5 md:px-12 py-16 border-b border-gray-100">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-baseline justify-between gap-4 mb-10">
        <div class="flex items-baseline gap-4">
          <span class="bg-[#C4A072] text-[#1A100C] text-[10px] font-bold px-2.5 py-1 tracking-[0.2em] uppercase">New</span>
          <h2 class="text-xl font-bold tracking-tight uppercase">Novedades T3R · Gama 2026</h2>
        </div>
        {novedades.length > 3 && (
          <div class="hidden md:flex items-center gap-2">
            <button id="carousel-prev" type="button" aria-label="Anterior"
              class="w-9 h-9 flex items-center justify-center border border-gray-200 hover:border-[#1A100C] transition-colors cursor-pointer">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <button id="carousel-next" type="button" aria-label="Siguiente"
              class="w-9 h-9 flex items-center justify-center border border-gray-200 hover:border-[#1A100C] transition-colors cursor-pointer">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>
        )}
      </div>

      {novedades.length > 0 ? (
        <div id="novedades-carousel" class="flex gap-6 overflow-x-auto snap-x snap-mandatory pb-4 mb-6" style="scrollbar-width: none;">
          {novedades.map((p, i) => (
            <a href="/t3r" data-reveal data-delay={String((i % 3) + 1)} class="group cursor-pointer snap-start shrink-0 block" style="width: clamp(220px, 68vw, 360px);">
              <div class="relative overflow-hidden bg-[#f0e4d3] mb-5" style="aspect-ratio: 4/3;">
                <span class="absolute top-4 left-4 z-10 bg-white text-[#1A100C] text-xs font-bold px-3 py-1.5 tracking-[0.15em] uppercase">New</span>
                <img src={p.imagen ?? '/logo_t3r.png'} alt={p.name}
                  class={p.imagen ? "absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]" : "absolute inset-0 m-auto h-14 opacity-20"}
                  loading="lazy"
                  onerror="this.onerror=null; this.src='/logo_t3r.png'; this.className='absolute inset-0 m-auto h-14 opacity-20';" />
              </div>
              <p class="text-xs text-gray-400 tracking-[0.25em] uppercase mb-1.5">{p.category}</p>
              <h3 class="font-semibold text-xl text-gray-900 mb-1.5">{p.name}</h3>
              <p class="text-base text-gray-400">Consulta disponibilidad</p>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-sm text-gray-400 mb-10">Catálogo en preparación — vuelve pronto.</p>
      )}

      <div class="flex justify-center">
        <a href="/catalogo"
          class="paint-fill-button paint-fill-button--dark border border-[#1A100C] text-[#1A100C] text-xs font-semibold px-10 py-4 tracking-[0.2em] uppercase cursor-pointer">
          <span class="relative z-10">Ver catálogo completo</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ BANNER T3R ═══ -->
  <section class="relative overflow-hidden group" style="height: 460px;">
    <a href="/t3r" class="absolute inset-0 z-20"></a>
    <img
      src="/catalogo_t3r/combos/combos_1.jpg"
      alt="T3R The Three Riders"
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      style="object-position: center 30%;"
      loading="lazy"
      decoding="async"
    />
    <div class="absolute inset-0 bg-[#1A100C]/55"></div>
    <div class="pointer-events-none absolute inset-0 z-30 flex flex-col items-center justify-center px-8 text-center">
      <img data-reveal src="/logo_blanco_t3r.png" alt="T3R" class="h-20 md:h-36 w-auto mb-6 opacity-95" />
      <p data-reveal data-delay="1" class="text-xs text-white/75 tracking-[0.35em] uppercase mb-8">The Three Riders · Componentes fundamentales</p>
      <a data-reveal data-delay="2" href="/t3r"
        class="paint-fill-button pointer-events-auto border border-white text-white text-xs font-semibold px-10 py-4 tracking-[0.2em] uppercase cursor-pointer relative z-30">
        <span class="relative z-10">Saber más</span>
      </a>
    </div>
  </section>

  <!-- ═══ BANNER TRANSFER ═══ -->
  <section class="relative overflow-hidden group" style="height: 520px;">
    <a href="/transfer" class="absolute inset-0 z-20"></a>
    <img
      src="/catalogo_transferbike/bici_transferbike.jpeg"
      alt="Transfer Bike"
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
      decoding="async"
    />
    <div class="absolute inset-0 bg-[#111]/45"></div>
    <div class="pointer-events-none absolute inset-0 z-30 flex flex-col items-center justify-center px-8 text-center">
      <img data-reveal src="/logo_transfer.png" alt="Transfer Bike" class="h-20 md:h-36 w-auto brightness-0 invert mb-6" />
      <p data-reveal data-delay="1" class="text-xs text-white/75 tracking-[0.35em] uppercase mb-8">Bicicletas · Una bici, cada día</p>
      <a data-reveal data-delay="2" href="/transfer"
        class="paint-fill-button pointer-events-auto border border-white text-white text-xs font-semibold px-10 py-4 tracking-[0.2em] uppercase cursor-pointer relative z-30">
        <span class="relative z-10">Descubre</span>
      </a>
    </div>
  </section>

  <!-- ═══ BANNER WHIPP-OFF ═══ -->
  <section class="relative overflow-hidden group" style="height: 520px;">
    <a href="/whipp-off" class="absolute inset-0 z-20"></a>
    <img
      src="/catalogo_whipoff/WHIP_OFF_1.jpg"
      alt="Whipp-Off"
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
      decoding="async"
    />
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="pointer-events-none absolute inset-0 z-30 flex flex-col items-center justify-center px-8 text-center">
      <img data-reveal src="/logo_whipoff.png" alt="Whipp-Off" class="h-24 md:h-40 w-auto brightness-0 invert mb-8" />
      <a data-reveal data-delay="1" href="/whipp-off"
        class="paint-fill-button pointer-events-auto border border-white text-white text-xs font-semibold px-10 py-4 tracking-[0.2em] uppercase cursor-pointer relative z-30">
        <span class="relative z-10">Saber más</span>
      </a>
    </div>
  </section>

  <!-- ═══ DISTRIBUIDORA OFICIAL DE ═══ -->
  <section class="bg-[#0a0808] px-5 md:px-12 py-24 text-center">
    <p class="text-[11px] text-white/40 tracking-[0.4em] uppercase mb-8">Fundamental, distribuidora oficial de</p>
    <div class="flex flex-col items-center gap-3">
      <a href="/t3r" class="text-xl md:text-3xl font-bold text-white hover:text-[#C4A072] transition-colors tracking-tight">T3R · The Three Riders</a>
      <a href="/whipp-off" class="text-xl md:text-3xl font-bold text-white hover:text-[#C4A072] transition-colors tracking-tight">Whipp-Off</a>
      <a href="/transfer" class="text-xl md:text-3xl font-bold text-white hover:text-[#C4A072] transition-colors tracking-tight">Transfer Bike</a>
    </div>
  </section>

  <!-- ═══ INFO ROW ═══ -->
  <section class="bg-[#F0EDE8] px-5 md:px-12 py-16">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12 text-center">
      <div>
        <p class="text-[10px] text-gray-400 tracking-[0.3em] uppercase mb-3">Envío</p>
        <h3 class="font-bold text-base mb-2">Entrega a domicilio</h3>
        <p class="text-sm text-gray-500 leading-relaxed">Gestionamos el envío de cualquier referencia bajo solicitud, directo a tienda o domicilio.</p>
      </div>
      <div>
        <p class="text-[10px] text-gray-400 tracking-[0.3em] uppercase mb-3">Fundamental Care</p>
        <h3 class="font-bold text-base mb-2">Soporte técnico</h3>
        <p class="text-sm text-gray-500 leading-relaxed">Resolvemos cualquier consulta sobre piezas, compatibilidad o garantía.</p>
      </div>
      <div>
        <p class="text-[10px] text-gray-400 tracking-[0.3em] uppercase mb-3">Newsletter</p>
        <h3 class="font-bold text-base mb-3">Mantente informado</h3>
        <form class="flex">
          <input type="email" placeholder="tu@email.com"
            class="border border-gray-300 bg-white px-4 py-3 text-sm flex-1 outline-none focus:border-[#1A100C] transition-colors" />
          <button type="submit" class="bg-[#1A100C] text-white text-sm px-5 py-3 hover:bg-black transition-colors">Suscribirme</button>
        </form>
      </div>
    </div>
  </section>

  <!-- ═══ FOOTER ═══ -->
  <footer class="bg-[#1A100C] px-5 md:px-12 pt-14 pb-10">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 mb-12 pb-12 border-b border-white/10">
        <div>
          <p class="text-base font-bold text-white mb-3">Fundamental</p>
          <p class="text-sm text-white/55 leading-relaxed">
            Distribuidora de componentes, bicicletas y ropa MTB. Madrid, España.
          </p>
        </div>
        <div>
          <p class="text-xs text-white/40 tracking-[0.25em] uppercase mb-4">Servicio al cliente</p>
          <div class="flex flex-col gap-2">
            <a href="/contacto" class="text-sm text-white/55 hover:text-[#C4A072] transition-colors">Contacto</a>
            <a href="/contacto" class="text-sm text-white/55 hover:text-[#C4A072] transition-colors">Envíos y devoluciones</a>
            <a href="/contacto" class="text-sm text-white/55 hover:text-[#C4A072] transition-colors">Garantía</a>
          </div>
        </div>
        <div>
          <p class="text-xs text-white/40 tracking-[0.25em] uppercase mb-4">Marcas</p>
          <div class="flex flex-col gap-2">
            <a href="/t3r" class="text-sm text-white/55 hover:text-[#C4A072] transition-colors">T3R</a>
            <a href="/transfer" class="text-sm text-white/55 hover:text-[#C4A072] transition-colors">Transfer</a>
            <a href="/whipp-off" class="text-sm text-white/55 hover:text-[#C4A072] transition-colors">Whipp-Off</a>
          </div>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row items-center sm:items-center justify-between gap-2 text-center sm:text-left">
        <p class="text-xs text-white/25">© 2026 Fundamental — Todos los derechos reservados</p>
        <p class="text-xs text-white/25">Madrid · España</p>
      </div>
    </div>
  </footer>

  <script>
    const observer = new IntersectionObserver(
      (entries) => entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }
      }),
      { threshold: 0.1 }
    );
    document.addEventListener('astro:page-load', () => {
      document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));
    });
  </script>

  <script>
    document.addEventListener('astro:page-load', () => {
      const track = document.getElementById('novedades-carousel');
      const prev = document.getElementById('carousel-prev');
      const next = document.getElementById('carousel-next');
      if (!track || !prev || !next) return;

      const scrollByCard = (dir: number) => {
        const card = track.querySelector(':scope > div');
        const cardWidth = card ? card.getBoundingClientRect().width + 24 : 300;
        track.scrollBy({ left: dir * cardWidth, behavior: 'smooth' });
      };
      prev.addEventListener('click', () => scrollByCard(-1));
      next.addEventListener('click', () => scrollByCard(1));
    });
  </script>

</Layout>
