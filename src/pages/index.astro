---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { supabase } from '../lib/supabase';

const { data: products, error } = await supabase
  .from('productos_t3r')
  .select('nombre, categoria, descripcion_corta, sku')
  .eq('activo', true)
  .in('sku', [
    'T3R-DISCO-6T-160',
    'T3R-PAST-SRAM-GDE',
    'T3R-PED-XCO',
    'T3R-PED-EBIKE',
    'T3R-VLV-ELITE-42',
    'T3R-EJE-BSA-SH',
  ]);

if (error) console.error('Supabase productos error:', error.message);

const skus = (products ?? []).map((p: any) => p.sku);

const { data: imagenes, error: imgError } = await supabase
  .from('imagenes_productos')
  .select('producto_sku, url, orden')
  .in('producto_sku', skus)
  .eq('orden', 1);

if (imgError) console.error('Supabase imagenes error:', imgError.message);

const imgMap: Record<string, string> = {};
(imagenes ?? []).forEach((i: any) => { imgMap[i.producto_sku] = i.url; });

const featured = (products ?? []).map((p: any) => ({
  category: p.categoria,
  name: p.nombre,
  description: p.descripcion_corta,
  ref: p.sku,
  imagen: imgMap[p.sku] ? `/${imgMap[p.sku]}` : null,
}));

const heroStrip = [
  { name: 'Discos de freno',    img: '/catalogo_t3r/discos_freno/discos_freno_center_lock_1.jpg', href: '/t3r' },
  { name: 'Pastillas de freno', img: '/catalogo_t3r/pastillas_freno/pastillas_freno_1.jpg',       href: '/t3r' },
  { name: 'Pedales plataforma', img: '/catalogo_t3r/pedal_plataforma/pedal_plataforma_1.jpg',     href: '/t3r' },
  { name: 'Pedales automáticos',img: '/catalogo_t3r/pedal_automatico/pedal_automatico_1.jpg',     href: '/t3r' },
  { name: 'Pedalier / BB',      img: '/catalogo_t3r/pedalier_1/pedalier_1_1.jpg',                href: '/t3r' },
  { name: 'Válvulas tubeless',  img: '/catalogo_t3r/valvula_tubeless/valvula_tubeless_1.jpg',     href: '/t3r' },
];

const valores = [
  {
    n: '01',
    title: 'Directo de fábrica',
    text: 'Sin eslabones innecesarios. El precio que pagas refleja el coste real del producto, no los márgenes acumulados.',
  },
  {
    n: '02',
    title: 'Testado por riders',
    text: 'Cada referencia ha pasado por nuestras manos. Los tres riders aprueban cada producto antes de que entre al catálogo.',
  },
  {
    n: '03',
    title: 'Fabricación contrastada',
    text: 'Mismas plantas que producen marcas de primer nivel internacional. La calidad no es nueva aquí — el precio sí.',
  },
];
---

<Layout title="Fundamental Bike Parts — Distribuidora T3R">

  <style is:global>
    @keyframes marquee {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .marquee-track { animation: marquee 28s linear infinite; }
    .marquee-wrap:hover .marquee-track { animation-play-state: paused; }
    @media (prefers-reduced-motion: reduce) { .marquee-track { animation: none; } }
    html { scroll-behavior: smooth; }

    [data-reveal] {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    [data-reveal].visible {
      opacity: 1;
      transform: translateY(0);
    }
    [data-delay="1"] { transition-delay: 0.1s; }
    [data-delay="2"] { transition-delay: 0.2s; }
    [data-delay="3"] { transition-delay: 0.3s; }
  </style>

  <!-- NAV -->
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-16 py-6 bg-[#090807]/85 backdrop-blur-md border-b border-white/5">
    <a href="/" class="font-display uppercase text-xl tracking-[-0.03em] text-white" style="font-weight: 600;" transition:name="nav-logo">Fundamental Bike Parts</a>
    <nav class="flex gap-10">
      <!-- <a href="/marcas" class="text-base text-white/70 hover:text-white transition-colors">Marcas</a> -->
      <a href="/t3r" class="text-base text-white/70 hover:text-white transition-colors">T3R</a>
      <a href="/nosotros" class="text-base text-white/70 hover:text-white transition-colors">Nosotros</a>
      <a href="/contacto" class="text-base text-white/70 hover:text-white transition-colors">Contacto</a>
    </nav>
  </header>

  <!-- ═══════════════════════════════════════════════ HERO ═══ -->
  <section class="min-h-screen flex flex-col bg-[#090807]">

    <!-- Statement central -->
    <div class="flex-1 flex flex-col items-center justify-center text-center px-8 pt-28 pb-10">

      <!-- Eyebrow -->
      <div class="flex items-center gap-5 mb-10">
        <div class="w-14 h-px bg-[#C4A072]/30"></div>
        <p class="text-[10px] text-[#C4A072]/80 tracking-[0.5em] uppercase">Distribuidora oficial · Madrid</p>
        <div class="w-14 h-px bg-[#C4A072]/30"></div>
      </div>

      <!-- FUNDAMENTAL -->
      <h1
        class="font-bold text-white uppercase tracking-tight leading-[0.82] mb-4"
        style="font-size: clamp(72px, 11.8vw, 180px);"
      >
        Fundamental
      </h1>

      <!-- BIKE PARTS -->
      <p
        class="font-bold text-[#C4A072] uppercase tracking-[0.45em] mb-10"
        style="font-size: clamp(18px, 2.5vw, 38px);"
      >
        Bike&nbsp;Parts
      </p>

      <!-- Descripción -->
      <p class="text-white/40 text-base max-w-md leading-relaxed mb-12">
        Componentes T3R para distribuidoras y clientes finales. Más de 126 referencias disponibles bajo pedido.
      </p>

      <!-- CTAs -->
      <div class="flex items-center gap-4">
        <a
          href="#catalogo"
          class="bg-[#C4A072] text-[#090807] text-sm font-bold px-12 py-4 hover:bg-[#D4B280] transition-colors tracking-[0.1em] uppercase cursor-pointer"
        >
          Explorar catálogo
        </a>
        <a
          href="/t3r"
          class="border border-white/20 text-white/55 text-sm px-10 py-4 hover:border-[#C4A072]/60 hover:text-[#C4A072] transition-colors tracking-[0.08em] uppercase cursor-pointer"
        >
          Conocer T3R
        </a>
      </div>
    </div>

    <!-- Strip de categorías: primera mirada al catálogo -->
    <div class="flex border-t border-white/8" style="height: 220px;">
      {heroStrip.map((item, i) => (
        <a
          href={item.href}
          class="group relative overflow-hidden cursor-pointer flex-1"
          style={i > 0 ? 'border-left: 1px solid rgba(255,255,255,0.06);' : ''}
        >
          <img
            src={item.img}
            alt={item.name}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-[#090807]/62 group-hover:bg-[#090807]/30 transition-colors duration-400"></div>
          <div class="absolute inset-0 flex flex-col justify-end p-5">
            <p class="text-white/90 text-xs font-semibold tracking-[0.08em] uppercase leading-snug">{item.name}</p>
            <span class="text-[#C4A072] text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200 mt-1.5">Ver →</span>
          </div>
        </a>
      ))}
    </div>

  </section>

  <!-- ═══════════════════════════════════════════════ TICKER ═══ -->
  <div class="bg-[#C4A072] py-3 overflow-hidden marquee-wrap">
    <div class="flex whitespace-nowrap marquee-track">
      {Array(2).fill(null).map(() => (
        <span class="flex items-center">
          {['Discos de freno', 'Pastillas', 'Pedales plataforma', 'Pedales automáticos', 'Pedales carretera', 'Pedalier / BB', 'Puños', 'Válvulas tubeless', 'T3R · The Three Riders', 'Fundamental Bike Parts', 'Directo del fabricante', 'Sin intermediarios'].map(t => (
            <span class="font-bold text-[#090807] text-[10px] tracking-[0.3em] uppercase mx-7">
              {t} <span class="opacity-20 mx-2">·</span>
            </span>
          ))}
        </span>
      ))}
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════ CATÁLOGO ═══ -->
  <section id="catalogo" class="bg-[#0d0c0a] px-16 py-24">
    <div class="max-w-6xl mx-auto">

      <div class="flex items-end justify-between mb-12">
        <div data-reveal>
          <p class="text-xs text-[#C4A072] tracking-[0.4em] uppercase mb-3">Gama completa</p>
          <h2 class="text-[52px] font-bold text-white leading-tight tracking-tight">
            Lo que<br/>distribuimos.
          </h2>
        </div>
        <div data-reveal data-delay="2" class="text-right">
          <p class="text-white/25 text-sm mb-1">8 categorías</p>
          <p class="text-white/25 text-sm">+126 referencias</p>
        </div>
      </div>

      <!-- Grid 4x2 -->
      <div class="grid grid-cols-4 gap-px bg-white/5" data-reveal>
        {[
          { cat: 'Discos de freno',     refs: '+29', img: '/catalogo_t3r/discos_freno/discos_freno_center_lock_1.jpg',  href: '/t3r' },
          { cat: 'Pastillas de freno',  refs: '+50', img: '/catalogo_t3r/pastillas_freno/pastillas_freno_1.jpg',        href: '/t3r' },
          { cat: 'Pedales plataforma',  refs: '9',   img: '/catalogo_t3r/pedal_plataforma/pedal_plataforma_1.jpg',      href: '/t3r' },
          { cat: 'Pedales automáticos', refs: '9',   img: '/catalogo_t3r/pedal_automatico/pedal_automatico_1.jpg',      href: '/t3r' },
          { cat: 'Pedales carretera',   refs: '6',   img: '/catalogo_t3r/pedal_carretera/pedal_carretera_1.jpg',        href: '/t3r' },
          { cat: 'Pedalier / BB',       refs: '14',  img: '/catalogo_t3r/pedalier_1/pedalier_1_1.jpg',                  href: '/t3r' },
          { cat: 'Puños',               refs: '4',   img: '/catalogo_t3r/punos/puno_arandelas_ergonomicos.jpg',         href: '/t3r' },
          { cat: 'Válvulas tubeless',   refs: '5',   img: '/catalogo_t3r/valvula_tubeless/valvula_tubeless_1.jpg',      href: '/t3r' },
        ].map((item) => (
          <a
            href={item.href}
            class="group relative overflow-hidden bg-[#0d0c0a] cursor-pointer block"
            style="height: 240px;"
          >
            <img
              src={item.img}
              alt={item.cat}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-[#090807]/65 group-hover:bg-[#090807]/40 transition-colors duration-300"></div>
            <div class="absolute inset-0 flex flex-col justify-end p-7">
              <div class="flex items-end justify-between">
                <div>
                  <p class="text-white font-semibold text-sm leading-tight mb-1">{item.cat}</p>
                  <p class="text-white/35 text-xs">{item.refs} refs.</p>
                </div>
                <span class="text-[#C4A072] text-sm opacity-0 group-hover:opacity-100 transition-all duration-200 group-hover:translate-x-0 -translate-x-2">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ PRODUCTOS DESTACADOS ═══ -->
  <section class="bg-[#111] px-16 py-24 border-t border-white/5">
    <div class="max-w-6xl mx-auto">

      <div class="flex items-end justify-between mb-14">
        <div data-reveal>
          <p class="text-xs text-[#C4A072] tracking-[0.4em] uppercase mb-3">Selección T3R</p>
          <h2 class="text-[48px] font-bold text-white leading-tight tracking-tight">Los más solicitados.</h2>
        </div>
        <a href="/t3r" data-reveal data-delay="2"
          class="text-sm text-white/40 hover:text-[#C4A072] transition-colors tracking-[0.15em] uppercase">
          Ver toda la gama →
        </a>
      </div>

      <div class="grid grid-cols-3 gap-px bg-white/5">
        {featured.map((p, i) => (
          <div data-reveal data-delay={String(i % 3 + 1)} class="group bg-[#111] flex flex-col cursor-pointer">

            <!-- Imagen -->
            <div class="relative overflow-hidden bg-[#1a1818]" style="height: 280px;">
              {p.imagen ? (
                <img
                  src={p.imagen}
                  alt={p.name}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center">
                  <img src="/logo_blanco_t3r.png" alt="T3R" class="h-10 opacity-10" />
                </div>
              )}
            </div>

            <!-- Info -->
            <div class="p-7 flex flex-col flex-1 border-t border-white/5">
              <p class="text-[10px] text-[#C4A072] tracking-[0.3em] uppercase mb-3">{p.category}</p>
              <h3 class="text-white font-semibold text-lg leading-snug mb-2 flex-1">{p.name}</h3>
              {p.description && (
                <p class="text-white/40 text-sm leading-relaxed mb-5">{p.description}</p>
              )}
              <div class="flex items-center justify-between pt-4 border-t border-white/8 mt-auto">
                <p class="text-white/30 text-xs tracking-[0.1em]">{p.ref}</p>
                <a
                  href="/contacto"
                  class="text-xs text-white/50 group-hover:text-[#C4A072] transition-colors tracking-[0.15em] uppercase flex items-center gap-1.5"
                >
                  Solicitar
                  <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
                </a>
              </div>
            </div>

          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ POR QUÉ FUNDAMENTAL ═══ -->
  <section class="bg-[#0a0908] px-16 py-24 border-t border-white/5">
    <div class="max-w-6xl mx-auto">

      <div class="mb-16" data-reveal>
        <p class="text-xs text-[#C4A072] tracking-[0.4em] uppercase mb-4">Nuestra forma de trabajar</p>
        <h2 class="text-[48px] font-bold text-white leading-tight tracking-tight">Por qué Fundamental.</h2>
      </div>

      <div class="grid grid-cols-3 gap-px bg-white/5">
        {valores.map((v, i) => (
          <div data-reveal data-delay={String(i + 1)} class="bg-[#0a0908] p-10">
            <p class="text-[#C4A072] text-3xl font-bold mb-8">{v.n}</p>
            <h3 class="text-white font-semibold text-xl mb-5 leading-snug">{v.title}</h3>
            <p class="text-white/45 text-sm leading-relaxed">{v.text}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ CTA FINAL ═══ -->
  <section class="bg-[#1A100C] px-16 py-36 relative overflow-hidden">
    <!-- Subtle grid texture -->
    <div class="absolute inset-0 opacity-[0.03]"
      style="background-image: repeating-linear-gradient(0deg, #C4A072 0, #C4A072 1px, transparent 0, transparent 56px), repeating-linear-gradient(90deg, #C4A072 0, #C4A072 1px, transparent 0, transparent 56px);">
    </div>

    <div class="max-w-6xl mx-auto relative z-10 flex items-center justify-between gap-20">
      <div>
        <p data-reveal class="text-xs text-[#C4A072] tracking-[0.4em] uppercase mb-6">Fundamental Bike Parts</p>
        <h2 data-reveal data-delay="1" class="text-[72px] font-bold text-white leading-[0.88] tracking-tight mb-8">
          ¿Listo para<br/>
          <span class="text-[#C4A072]">pedir?</span>
        </h2>
        <p data-reveal data-delay="2" class="text-white/45 text-base leading-relaxed max-w-md">
          Consúltanos cualquier referencia T3R. Gestionamos pedidos para distribuidoras y tiendas con disponibilidad y plazo confirmados.
        </p>
      </div>
      <div data-reveal data-delay="3" class="flex flex-col gap-4 shrink-0">
        <a
          href="/contacto"
          class="bg-[#C4A072] text-[#1A100C] text-sm font-bold px-14 py-5 hover:bg-[#D4B280] transition-colors tracking-[0.1em] uppercase text-center cursor-pointer"
        >
          Solicitar catálogo
        </a>
        <a
          href="/t3r"
          class="border border-white/20 text-white/50 text-sm px-14 py-4 hover:border-white/40 hover:text-white transition-colors tracking-[0.08em] uppercase text-center cursor-pointer"
        >
          Conocer T3R →
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ FOOTER ═══ -->
  <footer class="bg-[#080706] border-t border-white/5 px-16 py-10 flex items-center justify-between">
    <div>
      <p class="text-sm font-semibold text-white mb-1">Fundamental Bike Parts</p>
      <p class="text-xs text-white/35">Distribuidora oficial T3R · Madrid, España</p>
    </div>
    <div class="flex items-center gap-8">
      <a href="/t3r" class="text-xs text-white/30 hover:text-white/60 transition-colors tracking-[0.1em] uppercase">T3R</a>
      <a href="/nosotros" class="text-xs text-white/30 hover:text-white/60 transition-colors tracking-[0.1em] uppercase">Nosotros</a>
      <a href="/contacto" class="text-xs text-white/30 hover:text-white/60 transition-colors tracking-[0.1em] uppercase">Contacto</a>
    </div>
    <p class="text-xs text-white/20">© 2026 FUNDAMENTAL</p>
  </footer>

  <script>
    // Scroll reveal
    const observer = new IntersectionObserver(
      (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } }),
      { threshold: 0.12 }
    );
    document.addEventListener('astro:page-load', () => {
      document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));
    });
  </script>

</Layout>
