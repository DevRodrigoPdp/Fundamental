---
import path from 'path';
import { existsSync } from 'fs';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import BackToTop from '../components/BackToTop.astro';
import '../styles/global.css';
import { supabase } from '../lib/supabase';
import { SITE } from '../config/site';

const CONTACT_EMAIL = 'hola@fundamentalbikeparts.com'; // TODO: confirmar email real

const { data: products, error } = await supabase
  .from('productos_t3r')
  .select('nombre, categoria, subcategoria, descripcion_corta, sku')
  .eq('activo', true)
  .order('categoria', { ascending: true });

if (error) console.error('Supabase productos error:', error.message);

const skus = (products ?? []).map((p: any) => p.sku);

const { data: imagenes } = skus.length > 0
  ? await supabase
      .from('imagenes_productos')
      .select('producto_sku, url, orden')
      .in('producto_sku', skus)
      .eq('orden', 1)
  : { data: [] };

const imgMap: Record<string, string> = {};
(imagenes ?? []).forEach((i: any) => {
  const rel = i.url.replace(/^\/+/, '');
  if (existsSync(path.join(process.cwd(), 'public', rel))) {
    imgMap[i.producto_sku] = `/${rel}`;
  }
});

const catalogoBase = (products ?? []).map((p: any) => ({
  nombre: p.nombre,
  categoria: p.categoria,
  subcategoria: p.subcategoria,
  descripcion: p.descripcion_corta,
  sku: p.sku,
  imagen: imgMap[p.sku] ?? null,
}));

const diskFamilies = [
  { prefix: 'T3R-DISCO-6T-', nombre: 'Discos de freno 6 tornillos' },
  { prefix: 'T3R-DISCO-CL-', nombre: 'Discos de freno Center Lock' },
];

const groupedPrefixes = new Set<string>();
const catalogo = catalogoBase.flatMap((item: any) => {
  const family = diskFamilies.find(({ prefix }) => item.sku.startsWith(prefix));
  if (!family) return [item];
  if (groupedPrefixes.has(family.prefix)) return [];
  groupedPrefixes.add(family.prefix);

  const variants = catalogoBase
    .filter((candidate: any) => candidate.sku.startsWith(family.prefix))
    .sort((a: any, b: any) => Number(a.sku.match(/(\d+)$/)?.[1]) - Number(b.sku.match(/(\d+)$/)?.[1]));
  const representative = variants.find((variant: any) => variant.sku.endsWith('-140')) ?? variants[0];
  const sizes = variants.map((variant: any) => variant.sku.match(/(\d+)$/)?.[1]).filter(Boolean);

  return [{
    ...representative,
    nombre: family.nombre,
    descripcion: `Disponible en ${sizes.join(', ')} mm. Selecciona la medida dentro del producto.`,
    refLabel: `${sizes.join(' · ')} mm`,
    searchSku: variants.map((variant: any) => variant.sku).join(' '),
  }];
});
---

<Layout
  title="Catálogo T3R | Componentes para bicicleta"
  description="Consulta el catálogo T3R de componentes para bicicleta: frenos, pedales, pedalieres, puños, válvulas, cables, bolsas y accesorios."
  image="/catalogo_t3r/combos/combos_3.jpg"
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Catálogo T3R',
    description: 'Catálogo de recambios y componentes T3R para bicicletas.',
    url: `${SITE.url}/catalogo`,
    isPartOf: { '@id': `${SITE.url}/#website` },
  }}
>

  <Nav />
  <BackToTop />

  <!-- HERO + BUSCADOR -->
  <section class="px-5 md:px-16 pt-32 md:pt-36 pb-16">
    <p data-reveal class="text-sm text-[#6B8CAE] tracking-[0.3em] uppercase mb-6">Marca · T3R</p>
    <h1 data-reveal data-delay="1" class="text-[40px] md:text-[64px] font-bold leading-tight mb-6">
      Catálogo T3R.
    </h1>
    <p data-reveal data-delay="2" class="text-lg text-[#6B8CAE] max-w-lg leading-relaxed mb-10">
      Cada referencia se sirve bajo solicitud. Filtra por nombre, categoría o referencia y te enviamos disponibilidad, plazo y precio.
    </p>

    <div data-reveal data-delay="3" class="relative max-w-xl">
      <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M19 11a8 8 0 11-16 0 8 8 0 0116 0z" />
      </svg>
      <input
        id="search-input"
        type="search"
        placeholder="Buscar por nombre, categoría o referencia..."
        class="w-full border border-gray-300 pl-12 pr-12 py-3.5 text-base outline-none focus:border-black transition-colors [&::-webkit-search-cancel-button]:hidden"
        autocomplete="off"
        aria-label="Buscar en el catálogo"
        aria-controls="product-grid"
      />
      <button id="search-clear" type="button" class="hidden absolute right-3 top-1/2 -translate-y-1/2 p-2 text-gray-400 hover:text-black transition-colors" aria-label="Limpiar búsqueda">
        <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="m6 6 12 12M18 6 6 18"/></svg>
      </button>
    </div>
    <p id="search-status" class="mt-3 text-xs text-gray-400" role="status" aria-live="polite"></p>
  </section>

  <!-- GRID PRODUCTOS -->
  <section class="px-5 md:px-16 pb-32">
    {catalogo.length > 0 ? (
      <>
        <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-white">
          {catalogo.map((p, i) => (
            <div
              data-product-card
              data-search={`${p.nombre} ${p.categoria} ${p.subcategoria ?? ''} ${p.sku}`.toLowerCase()}
              data-name={p.nombre}
              data-category={p.categoria}
              data-subcategory={p.subcategoria ?? ''}
              data-sku={p.searchSku ?? p.sku}
              data-reveal data-delay={String(i % 4)}
              class="group bg-white border border-gray-200 flex flex-col"
            >
              <a href={`/catalogo/${p.sku}`} class="block cursor-pointer">
                <div class="relative overflow-hidden bg-white" style="aspect-ratio: 16/10;">
                  {p.imagen ? (
                    <img
                      src={p.imagen}
                      alt={p.nombre}
                      class="absolute inset-0 w-full h-full object-contain p-6 md:p-8 transition-transform duration-500 group-hover:scale-[1.02]"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : (
                    <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 bg-white text-gray-300">
                      <img src="/logo_t3r.png" alt="T3R" class="w-24 md:w-28 opacity-25 grayscale" loading="lazy" />
                      <p class="text-[10px] tracking-[0.25em] uppercase text-gray-300">Foto próximamente</p>
                    </div>
                  )}
                </div>
                <div class="px-7 pt-7">
                  <p class="text-[10px] text-gray-400 tracking-[0.25em] uppercase mb-2">{p.subcategoria ?? p.categoria}</p>
                  <h3 class="font-bold text-lg mb-2 leading-snug group-hover:text-[#6B8CAE] transition-colors">{p.nombre}</h3>
                  {p.descripcion && (
                    <p class="text-sm text-gray-500 leading-relaxed mb-5">{p.descripcion}</p>
                  )}
                </div>
              </a>
              <div class="px-7 pb-7 flex flex-col flex-1">
                <div class="flex flex-col items-start gap-4 mt-auto pt-4 border-t border-gray-100 min-[420px]:flex-row min-[420px]:items-center min-[420px]:justify-between">
                  <div class="min-w-0">
                    <p class="text-xs text-gray-400">{p.refLabel ?? p.sku}</p>
                    <p class="text-xs text-gray-400">Consulta disponibilidad</p>
                  </div>
                  <a
                    href={`mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent('Solicitud T3R — ' + p.nombre)}&body=${encodeURIComponent(`Hola,\n\nMe interesa el siguiente producto T3R:\n\nProducto: ${p.nombre}\nReferencia (SKU): ${p.sku}\nCategoría: ${p.categoria}${p.subcategoria ? ' / ' + p.subcategoria : ''}\n\nPor favor, indícame disponibilidad y precio.\n\nGracias.`)}`}
                    class="text-sm font-medium inline-flex items-center gap-1 shrink-0 cursor-pointer"
                  >
                    Solicitar
                    <span class="inline-block transition-transform duration-200 group-hover:translate-x-1">→</span>
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
        <p id="empty-state" class="hidden text-center text-gray-400 text-base py-20">
          No hay referencias que coincidan con tu búsqueda.
        </p>
      </>
    ) : (
      <p class="text-gray-400 text-base">Catálogo en preparación — vuelve pronto.</p>
    )}
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-gray-100 px-5 md:px-16 py-10 flex flex-col md:flex-row items-center md:items-start justify-between gap-4 text-center md:text-left">
    <div>
      <p class="text-base font-bold mb-2">T3R Fundamental</p>
      <p class="text-sm text-gray-400 max-w-[240px] leading-relaxed">
        Distribuidora de componentes profesionales para ciclismo. Madrid, España.
      </p>
    </div>
    <p class="text-sm text-gray-400">© 2026 FUNDAMENTAL</p>
  </footer>

  <script>
    document.addEventListener('astro:page-load', () => {
      const input = document.getElementById('search-input');
      const grid = document.getElementById('product-grid');
      const cards = [...document.querySelectorAll('[data-product-card]')];
      const emptyState = document.getElementById('empty-state');
      const clearButton = document.getElementById('search-clear');
      const status = document.getElementById('search-status');
      if (!input) return;

      const normalize = (value) => value
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, ' ')
        .trim();

      const aliases = new Map([
        ['6t', '6 tornillos'],
        ['centerlock', 'center lock'],
        ['cl', 'center lock'],
        ['rotor', 'disco'],
        ['brake', 'freno'],
        ['pads', 'pastillas'],
        ['bici', 'bicicleta'],
      ]);

      const oneEditAway = (term, word) => {
        if (term === word) return true;
        if (Math.abs(term.length - word.length) > 1) return false;
        let i = 0;
        let j = 0;
        let edits = 0;
        while (i < term.length && j < word.length) {
          if (term[i] === word[j]) { i++; j++; continue; }
          if (++edits > 1) return false;
          if (term.length > word.length) i++;
          else if (word.length > term.length) j++;
          else { i++; j++; }
        }
        return edits + (i < term.length || j < word.length ? 1 : 0) <= 1;
      };

      const searchableCards = cards.map((card, index) => {
        const fields = {
          name: normalize(card.dataset.name || ''),
          category: normalize(card.dataset.category || ''),
          subcategory: normalize(card.dataset.subcategory || ''),
          sku: normalize(card.dataset.sku || ''),
        };
        return {
          card,
          index,
          fields,
          words: Object.values(fields).join(' ').split(' '),
        };
      });

      const termScore = (term, item) => {
        if (item.fields.sku.includes(term)) return 30;
        if (item.fields.name.split(' ').some((word) => word.startsWith(term))) return 24;
        if (item.fields.name.includes(term)) return 18;
        if (item.fields.subcategory.includes(term)) return 12;
        if (item.fields.category.includes(term)) return 8;
        if (term.length >= 4 && item.words.some((word) => oneEditAway(term, word))) return 4;
        return 0;
      };

      const filter = () => {
        const rawQuery = input.value.trim();
        const normalizedQuery = normalize(rawQuery);
        const expandedQuery = aliases.get(normalizedQuery) || normalizedQuery;
        const terms = expandedQuery.split(' ').filter(Boolean);

        const results = searchableCards.map((item) => {
          const scores = terms.map((term) => termScore(term, item));
          const match = terms.length === 0 || scores.every((score) => score > 0);
          let score = scores.reduce((total, value) => total + value, 0);
          if (expandedQuery && item.fields.name.includes(expandedQuery)) score += 50;
          if (expandedQuery && item.fields.sku.includes(expandedQuery)) score += 60;
          return { ...item, match, score };
        }).sort((a, b) => b.score - a.score || a.index - b.index);

        let visibleCount = 0;
        results.forEach((result) => {
          result.card.style.display = result.match ? '' : 'none';
          if (result.match) visibleCount++;
          grid?.append(result.card);
        });

        if (emptyState) emptyState.classList.toggle('hidden', visibleCount > 0);
        clearButton?.classList.toggle('hidden', !rawQuery);
        if (status) status.textContent = rawQuery
          ? `${visibleCount} ${visibleCount === 1 ? 'resultado' : 'resultados'}`
          : `${cards.length} productos`;

        const url = new URL(window.location.href);
        rawQuery ? url.searchParams.set('q', rawQuery) : url.searchParams.delete('q');
        history.replaceState({}, '', url);
      };

      input.addEventListener('input', filter);
      clearButton?.addEventListener('click', () => {
        input.value = '';
        filter();
        input.focus();
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === '/' && document.activeElement !== input) {
          event.preventDefault();
          input.focus();
        }
      });

      // Precarga la búsqueda si llega ?q= en la URL (ej. desde los enlaces de categoría en /t3r)
      const params = new URLSearchParams(window.location.search);
      const initialQuery = params.get('q');
      if (initialQuery) {
        input.value = initialQuery;
      }
      filter();
    });
  </script>

</Layout>
