---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { Factory, Bike, ShieldCheck, Timer, MapPin, ExternalLink, Search } from 'lucide-astro';
import '../styles/global.css';

const puntosVenta = [
  { nombre: 'The Bike Village SL', direccion: 'Cl Corts 5', poblacion: 'Cabrera de Mar', cp: '08349', tel: '936387251', mail: 'compras@thebikevillage.com' },
  { nombre: 'Terrabike Terrassa, SL', direccion: 'Cl Urquinaona, 78', poblacion: 'Terrassa', cp: '08222', tel: '937838007 / 606829698', mail: 'ventas@terra-bike.com' },
  { nombre: 'Ravet Bike SL', direccion: 'Cl Joanot Martorell, 272', poblacion: 'Granollers', cp: '08403', tel: '935106108', mail: 'info@ravetbike.com' },
  { nombre: 'Fernando Torres Probike, SLU', direccion: 'Cl Camino Instituto, 12', poblacion: 'Llerena', cp: '06900', tel: '924871670', mail: 'info@fernandotorresprobikes.com' },
  { nombre: 'Cicles Vic SL', direccion: 'C/ Eix Onze de Setembre, 48', poblacion: 'Vic', cp: '08500', tel: '938 86 30 49', mail: 'ciclesvic@gmail.com' },
  { nombre: 'Bici O Con Franquicia, SL', direccion: 'Baixada Pontillón, 40', poblacion: 'Vigo (Pontevedra)', cp: '36210', tel: '', mail: 'biciocon@biciocon.com' },
  { nombre: 'Moto Bike, SL', direccion: 'Camiño Vello de Castela, 4 Bajo', poblacion: 'Pontevedra', cp: '36002', tel: '', mail: 'info@motobikepontevedra.com' },
  { nombre: 'Bici Buru Águilas', direccion: 'C/ Alfonso Ortega Carmona, Nº 5 A, Esc. 1, Bajo A', poblacion: 'Águilas (Murcia)', cp: '30880', tel: '968 413 240 / 649 44 33 43', mail: 'info@bicisburu.com' },
  { nombre: 'Cicles AB Castelló SL', direccion: "Calle Vall d'Uixó 41 - Bj 1", poblacion: 'Castellón de la Plana', cp: '12004', tel: '964220124', mail: 'ciclesab@ciclesab.com' },
  { nombre: "Cuesto's Bike", direccion: 'C/ Pedro Pidal Arroyo, 2', poblacion: 'Villaviciosa (Asturias)', cp: '33300', tel: '985 89 00 21', mail: 'cuetosbike@yahoo.es' },
];

const pilares = [
  { title: 'Directo de fábrica', text: 'Sin eslabones innecesarios. El precio refleja el coste real, no los márgenes acumulados de una cadena larga.', icon: 'factory' },
  { title: 'Testado por riders', text: 'Cada uno de los tres riders prueba y aprueba cada referencia antes de incluirla en el catálogo. Sin excepciones.', icon: 'rider' },
  { title: 'Fabricación contrastada', text: 'Mismas plantas que producen marcas internacionales con años de mercado. La calidad no es nueva, el precio sí.', icon: 'shield' },
  { title: 'Para durar', text: 'Productos pensados por y para durar. Que rindan a la altura durante toda su vida útil, sin concesiones.', icon: 'durability' },
];

const categorias = [
  {
    cat: 'Discos de freno',
    tag: 'Frenada',
    text: 'Control, mordida y medidas clave para montar una gama honesta sin inflar el precio.',
    img: '/catalogo_t3r/cutouts/disco_freno.png',
  },
  {
    cat: 'Pastillas de freno',
    tag: 'Frenada',
    text: 'Referencias compatibles para taller: claras, directas y pensadas para rotar bien.',
    img: '/catalogo_t3r/cutouts/pastillas_freno.png',
  },
  {
    cat: 'Pedales plataforma',
    tag: 'Contacto',
    text: 'Agarre y resistencia para uso diario, e-bike y montaña sin pagar por ruido de marca.',
    img: '/catalogo_t3r/cutouts/pedal_plataforma.png',
  },
  {
    cat: 'Pedales automáticos',
    tag: 'Contacto',
    text: 'Entrada, ajuste y fiabilidad para quien quiere rendimiento sin complicarse.',
    img: '/catalogo_t3r/cutouts/pedal_automatico.png',
  },
  {
    cat: 'Pedales carretera',
    tag: 'Road',
    text: 'Ligereza y apoyo para carretera, con el foco puesto en lo que realmente se nota.',
    img: '/catalogo_t3r/cutouts/pedal_carretera.png',
  },
  {
    cat: 'Pedalier / BB',
    tag: 'Transmisión',
    text: 'Ejes y pedalieres para resolver compatibilidades de taller sin convertirlo en ciencia oscura.',
    img: '/catalogo_t3r/cutouts/pedalier.png',
  },
  {
    cat: 'Puños',
    tag: 'Control',
    text: 'Tacto, comodidad y durabilidad para los puntos donde la bici se siente de verdad.',
    img: '/catalogo_t3r/cutouts/puno.png',
  },
  {
    cat: 'Válvulas tubeless',
    tag: 'Tubeless',
    text: 'Pequeñas piezas que tienen que funcionar siempre. Simple, preciso, sin teatro.',
    img: '/catalogo_t3r/cutouts/valvula.png',
  },
];

function categoriaCardLayout(index: number, total: number) {
  return 'min-h-[360px] lg:col-span-6 min-[2560px]:col-span-4';
}
---

<Layout title="T3R · The Three Riders — Fundamental">

  <style is:global>
    @keyframes marquee {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    .marquee-track { animation: marquee 22s linear infinite; }
    .marquee-wrap:hover .marquee-track { animation-play-state: paused; }
    .t3r-family-card::after {
      content: '';
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      height: 3px;
      background: #C4A072;
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .t3r-family-card:hover::after,
    .t3r-family-card:focus-visible::after {
      transform: scaleX(1);
    }
    @media (prefers-reduced-motion: reduce) { .marquee-track { animation: none; } }
    html { scroll-behavior: smooth; }
  </style>

  <Nav />

  <!-- HERO: split screen -->
  <section class="relative h-screen bg-[#1A100C] overflow-hidden">
    <img src="/catalogo_t3r/combos/combos_3.jpg" alt="T3R productos y packaging"
      class="absolute inset-0 w-full h-full object-cover" style="object-position: center 40%;"
      loading="eager" fetchpriority="high" decoding="async" />
    <div class="absolute inset-0" style="background: linear-gradient(to top, #1A100C 0%, rgba(26,16,12,0.75) 40%, rgba(26,16,12,0.2) 100%);"></div>

    <div class="absolute inset-0 flex flex-col justify-end px-5 md:px-16 pb-16 z-10">
      <div class="flex items-center gap-4 mb-6">
        <img src="/logo_blanco_t3r.png" alt="T3R" class="h-6 w-auto opacity-85" />
        <div class="w-px h-4 bg-white/20"></div>
        <p class="text-[10px] text-white/40 tracking-[0.35em] uppercase">The Three Riders</p>
      </div>
      <h1 class="text-[42px] sm:text-[56px] md:text-[88px] font-bold leading-[0.92] md:leading-[0.88] text-white tracking-tight mb-8">
        Desde el<br/>fabricante<br/>
        <span class="text-[#C4A072]">hasta la tienda.</span>
      </h1>
      <div class="flex items-start gap-6 max-w-sm mb-10">
        <div class="w-6 h-px bg-[#C4A072]/50 mt-3 shrink-0"></div>
        <p class="text-white/45 text-sm leading-relaxed">
          Componentes probados por nosotros. Sin intermediarios, al precio que debería tener desde el principio.
        </p>
      </div>
      <a href="/catalogo"
        class="bg-[#C4A072] text-[#1A100C] text-sm font-bold px-9 py-4 hover:bg-[#D4B280] transition-colors tracking-[0.1em] uppercase w-fit cursor-pointer">
        Ver catálogo
      </a>
    </div>
  </section>

  <!-- FAMILIAS DE PRODUCTO -->
  <section id="categorias" class="relative overflow-hidden bg-white px-5 py-24 text-[#111111] md:px-16 md:py-28">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_75%_0%,rgba(196,160,114,0.16),transparent_34%)]"></div>
    <div class="absolute inset-x-0 top-0 h-px bg-black/10"></div>
    <div class="relative mx-auto max-w-6xl min-[2560px]:max-w-[1800px]">
      <div class="mb-14 grid gap-8 md:grid-cols-[0.9fr_1.1fr] md:items-end" data-reveal>
        <div>
          <p class="mb-6 text-xs uppercase tracking-[0.35em] text-[#C4A072]">Gama T3R</p>
          <h2 class="text-[36px] font-bold leading-[0.95] tracking-tight md:text-[64px]">
            Componentes esenciales.<br />
            <span class="text-black/36">Sin rodeos.</span>
          </h2>
        </div>
        <p class="max-w-xl text-base leading-relaxed text-black/52 md:justify-self-end">
          Una selección pensada para tienda y taller: referencias claras, producto probado y precio donde tiene que estar. Menos escaparate, más pieza.
        </p>
      </div>

      <div class="grid gap-4 lg:grid-cols-12">
        {categorias.map((item, i) => (
          <a
            href={'/catalogo?q=' + encodeURIComponent(item.cat)}
            data-reveal
            data-delay={String(i % 4)}
            class:list={[
              't3r-family-card group relative overflow-hidden border border-black/10 bg-white transition-[border-color,box-shadow,background-color] duration-500 hover:border-[#C4A072]/55 hover:shadow-[0_24px_70px_rgba(17,17,17,0.10)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#C4A072]/60',
              categoriaCardLayout(i, categorias.length),
            ]}
          >
            <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(196,160,114,0.14),transparent_42%)] opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>

            <div class="relative z-10 flex min-h-[inherit] flex-col justify-between p-7 md:p-9">
              <div>
                <div class="mb-5 flex items-center gap-3">
                  <span class="h-px w-7 bg-[#C4A072]"></span>
                  <p class="text-[10px] uppercase tracking-[0.32em] text-[#C4A072]">{item.tag}</p>
                </div>
                <h3
                  class:list={[
                    'max-w-sm font-bold leading-[0.95] tracking-tight',
                    'text-3xl md:text-4xl',
                  ]}
                >
                  {item.cat}
                </h3>
                <p class="mt-5 max-w-sm text-sm leading-relaxed text-black/52">
                  {item.text}
                </p>
              </div>

              <div class="mt-10 flex items-end justify-between gap-6">
                <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.22em] text-black/56 transition-colors group-hover:text-[#C4A072]">
                  Ver referencias
                  <span class="transition-transform duration-300 group-hover:translate-x-1">→</span>
                </span>
                <img
                  src={item.img}
                  alt={item.cat}
                  class:list={[
                    'object-contain drop-shadow-[0_24px_34px_rgba(0,0,0,0.16)] transition-transform duration-700 group-hover:scale-105 group-hover:-rotate-2',
                    'h-52 w-52 md:h-64 md:w-64 min-[2560px]:h-72 min-[2560px]:w-72',
                  ]}
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TICKER -->
  <div class="bg-[#C4A072] py-3.5 overflow-hidden marquee-wrap">
    <div class="flex whitespace-nowrap marquee-track">
      {Array(2).fill(null).map(() => (
        <span class="flex items-center">
          {['Directo de fábrica', 'Probado por nosotros', 'Precio competitivo', 'Fabricación de prestigio', 'Para la tienda y el cliente', 'Pensado para durar', 'The Three Riders', 'Sin intermediarios'].map(t => (
            <span class="font-bold text-[#1A100C] text-xs tracking-[0.25em] uppercase mx-8">{t} <span class="opacity-25 mx-2">·</span></span>
          ))}
        </span>
      ))}
    </div>
  </div>

  <!-- HISTORIA — EL PROBLEMA -->
  <section class="bg-[#111] grid grid-cols-1 md:grid-cols-2">
    <div class="relative overflow-hidden h-64 md:h-auto md:min-h-[560px]">
      <img src="/catalogo_t3r/combos/combos_5.jpg" alt="T3R origen de la marca"
        class="absolute inset-0 w-full h-full object-cover" loading="lazy" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-t from-[#111]/40 via-transparent to-transparent"></div>
    </div>
    <div class="flex flex-col justify-center px-5 md:px-16 py-12 md:py-20" data-reveal>
      <p class="text-xs text-[#C4A072] tracking-[0.35em] uppercase mb-6">El problema</p>
      <h2 class="text-[34px] md:text-[48px] font-bold text-white leading-[0.95] tracking-tight mb-8">
        Una marca joven.<br/>
        <span class="text-[#C4A072]">Las ideas muy claras.</span>
      </h2>
      <p class="text-white/60 text-lg leading-relaxed max-w-md">
        Los mercados de todo el mundo sufren la competencia de precio que impone la globalización. T3R nace para cambiar esa ecuación: una cadena más corta significa precios más honestos para la tienda y para el cliente final.
      </p>
    </div>
  </section>

  <!-- PULL QUOTE -->
  <section class="bg-[#1A100C] px-5 md:px-16 py-24">
    <div class="max-w-4xl mx-auto text-center" data-reveal>
      <p class="text-[26px] md:text-[40px] font-bold text-white leading-snug">
        "Servir el mejor producto al mejor precio,<br/>
        <span class="text-[#C4A072]">para la tienda y el cliente final.</span>"
      </p>
      <p class="text-[#C4A072] text-xs tracking-[0.3em] uppercase mt-8">The Three Riders</p>
    </div>
  </section>

  <!-- HISTORIA — LA PROPUESTA -->
  <section class="bg-[#111] grid grid-cols-1 md:grid-cols-2">
    <div class="flex flex-col justify-center px-5 md:px-16 py-12 md:py-20 order-2" data-reveal>
      <p class="text-xs text-[#C4A072] tracking-[0.35em] uppercase mb-6">La propuesta</p>
      <h2 class="text-[28px] md:text-[40px] font-bold text-white leading-tight tracking-tight mb-8">
        Probado por nosotros<br/>antes que por nadie.
      </h2>
      <div class="space-y-5 max-w-md">
        <p class="text-white/60 text-lg leading-relaxed">
          Cada referencia ha pasado por nuestras manos antes de llegar aquí. Los tres riders prueban y aprueban cada producto: nada entra al catálogo sin esa garantía.
        </p>
        <p class="text-white/60 text-lg leading-relaxed">
          Fabricado en las mismas plantas que marcas de prestigio internacional, pensado para durar desde el ciclista amateur hasta el más experimentado.
        </p>
      </div>
    </div>
    <div class="relative overflow-hidden order-1 h-64 md:h-auto md:min-h-[560px]">
      <img src="/catalogo_t3r/combos/combos_7.jpg" alt="T3R probado por riders"
        class="absolute inset-0 w-full h-full object-cover" loading="lazy" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-t from-[#111]/40 via-transparent to-transparent"></div>
    </div>
  </section>

  <!-- FOTO SEPARADOR -->
  <div class="relative overflow-hidden h-[360px] md:h-[480px]">
    <img src="/catalogo_t3r/discos_freno/center_lock/discos_freno_center_lock_4.jpg" alt="Disco de freno T3R"
      class="absolute inset-0 w-full h-full object-cover" style="object-position: center 50%;"
      loading="lazy" decoding="async" />
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(26,16,12,0.9) 0%, rgba(26,16,12,0.5) 55%, rgba(26,16,12,0.1) 100%);"></div>
    <div class="absolute inset-0 flex items-center px-5 md:px-16">
      <div data-reveal class="max-w-lg">
        <p class="text-xs text-[#C4A072] tracking-[0.35em] uppercase mb-4">Fabricación contrastada</p>
        <p class="text-white text-2xl md:text-3xl font-bold leading-snug">
          Ningún producto entra al catálogo sin pasar por nuestras manos primero.
        </p>
      </div>
    </div>
  </div>

  <!-- PILARES -->
  <section class="relative overflow-hidden border-t border-white/5 bg-[#0f0e0c] px-5 py-24 md:px-16 md:py-28">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_15%_0%,rgba(196,160,114,0.10),transparent_30%)]"></div>
    <div class="relative mx-auto max-w-7xl">
      <div class="mb-14 grid gap-8 md:grid-cols-[0.9fr_1.1fr] md:items-end" data-reveal>
        <div>
          <p class="mb-5 text-xs uppercase tracking-[0.35em] text-[#C4A072]">Nuestros compromisos</p>
          <h2 class="text-4xl font-bold leading-[0.95] tracking-tight text-white md:text-6xl">
            Cuatro principios.<br />
            <span class="text-white/35">Cero atajos.</span>
          </h2>
        </div>
        <p class="max-w-xl text-base leading-relaxed text-white/48 md:justify-self-end">
          Lo que entra en una caja T3R tiene que cumplir una regla sencilla: aportar valor real a la tienda y funcionar cuando toca.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-4">
        {pilares.map((p, i) => (
          <article
            class="group relative min-h-[340px] overflow-hidden border border-white/8 bg-white/[0.025] p-7 transition-[border-color,background-color,box-shadow] duration-500 hover:border-[#C4A072]/45 hover:bg-[#C4A072]/[0.055] hover:shadow-[0_26px_70px_rgba(0,0,0,0.24)] md:p-8"
            data-reveal
            data-delay={String(i)}
          >
            <div class="absolute inset-x-0 bottom-0 h-[3px] origin-left scale-x-0 bg-[#C4A072] transition-transform duration-500 group-hover:scale-x-100"></div>

            <div class="mb-12 flex items-start">
              <div class="flex h-14 w-14 items-center justify-start text-[#C4A072] transition-colors duration-500 group-hover:text-[#D8B98D]">
                {p.icon === 'factory' && <Factory size={27} stroke-width={1.5} />}
                {p.icon === 'rider' && <Bike size={27} stroke-width={1.5} />}
                {p.icon === 'shield' && <ShieldCheck size={27} stroke-width={1.5} />}
                {p.icon === 'durability' && <Timer size={27} stroke-width={1.5} />}
              </div>
            </div>

            <div class="mb-6 h-px w-10 bg-[#C4A072]/55 transition-[width,background-color] duration-500 group-hover:w-20 group-hover:bg-[#C4A072]"></div>
            <h3 class="mb-4 max-w-[13rem] text-2xl font-semibold leading-tight tracking-tight text-white">
              {p.title}
            </h3>
            <p class="max-w-[17rem] text-sm leading-7 text-white/45 transition-colors duration-500 group-hover:text-white/62">
              {p.text}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- PACKAGING -->
  <section class="bg-[#111] grid grid-cols-1 md:grid-cols-2">
    <div class="relative overflow-hidden h-64 md:h-auto md:min-h-[480px]">
      <img src="/catalogo_t3r/combos/combos_8.jpg" alt="Packaging T3R"
        class="absolute inset-0 w-full h-full object-cover" loading="lazy" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-t from-[#111]/30 via-transparent to-transparent"></div>
    </div>
    <div class="flex flex-col justify-center px-5 md:px-16 py-12 md:py-20" data-reveal>
      <p class="text-xs text-[#C4A072] tracking-[0.35em] uppercase mb-6">La filosofía</p>
      <h2 class="text-[28px] md:text-[40px] font-bold text-white leading-tight mb-8">
        El packing no es<br/>el producto.
      </h2>
      <p class="text-white/60 text-lg leading-relaxed max-w-md mb-10">
        Cartón. Sin logotipos a color, sin envases llamativos. Cada euro que no gastamos en envoltorio es un euro que va al componente y al precio final.
      </p>
      <div class="border border-[#C4A072]/30 p-8 max-w-sm">
        <p class="text-[#C4A072] text-xs tracking-[0.3em] uppercase mb-4">Filosofía T3R</p>
        <p class="text-white text-xl font-bold leading-tight">
          "Minimizar el coste donde no afecta a la calidad."
        </p>
      </div>
    </div>
  </section>

  <!-- PUNTOS DE VENTA -->
  <section class="bg-[#0d0c0a] px-5 md:px-16 py-24 border-t border-white/5">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12" data-reveal>
        <p class="text-xs text-[#C4A072] tracking-[0.35em] uppercase mb-3">Tiendas físicas</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white">Encuéntranos cerca de ti</h2>
        <p class="text-white/45 text-base mt-4 max-w-xl leading-relaxed">
          T3R está disponible en estas tiendas especializadas repartidas por España. Pregunta por nuestras referencias directamente en el punto de venta más cercano.
        </p>
        <label class="mt-8 flex max-w-md items-center gap-3 border-b border-white/15 pb-3 text-white transition-colors focus-within:border-[#C4A072]">
          <Search size={18} stroke-width={1.6} class="shrink-0 text-[#C4A072]" aria-hidden="true" />
          <span class="sr-only">Buscar tienda por código postal</span>
          <input
            id="store-postcode-search"
            type="search"
            inputmode="numeric"
            maxlength="5"
            autocomplete="postal-code"
            placeholder="Buscar por código postal"
            class="w-full bg-transparent text-sm text-white outline-none placeholder:text-white/30"
          />
        </label>
      </div>
      <div class="grid gap-6 lg:grid-cols-[minmax(0,0.9fr)_minmax(480px,1.1fr)] lg:items-start" data-reveal>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-1">
          {puntosVenta.map((t, i) => {
            const mapQuery = [t.nombre, t.direccion, t.cp, t.poblacion, 'España'].join(', ');
            const mapsUrl = 'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(mapQuery);
            return (
              <article
                data-store-card
                data-store-postcode={t.cp}
                class:list={[
                  'border bg-[#0d0c0a] p-6 transition-[border-color,background-color] duration-300',
                  i === 0 ? 'is-active border-[#C4A072]/45 bg-[#C4A072]/[0.045]' : 'border-white/7',
                ]}
              >
                <h3 class="mb-3 text-base font-semibold text-white">{t.nombre}</h3>
                <a
                  href={mapsUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-map-query={mapQuery}
                  data-map-name={t.nombre}
                  class="group/address mb-4 flex items-start gap-3 text-sm leading-relaxed text-white/50 transition-colors hover:text-[#C4A072] focus-visible:outline-none focus-visible:text-[#C4A072]"
                  aria-label={'Mostrar ' + t.nombre + ' en Google Maps'}
                >
                  <MapPin size={17} stroke-width={1.6} class="mt-0.5 shrink-0 text-[#C4A072]" aria-hidden="true" />
                  <span>
                    <span class="block">{t.direccion}</span>
                    <span class="block">{t.poblacion} · {t.cp}</span>
                  </span>
                  <ExternalLink size={13} stroke-width={1.6} class="mt-1 ml-auto shrink-0 opacity-0 transition-opacity group-hover/address:opacity-100" aria-hidden="true" />
                </a>
                <div class="flex flex-wrap items-center gap-x-5 gap-y-1 text-xs">
                  {t.tel && (
                    <a href={`tel:${t.tel.split(' / ')[0].replace(/\s+/g, '')}`} class="text-white/40 transition-colors hover:text-[#C4A072]">{t.tel}</a>
                  )}
                  <a href={`mailto:${t.mail}`} class="text-white/40 transition-colors hover:text-[#C4A072]">{t.mail}</a>
                </div>
              </article>
            );
          })}
          <p id="store-search-message" class="hidden border border-white/8 p-6 text-sm leading-relaxed text-white/45">
            No encontramos una tienda con ese código postal. Prueba con los primeros dígitos o consulta el mapa.
          </p>
        </div>

        <aside class="sticky top-28 hidden overflow-hidden border border-white/8 bg-[#111] lg:block">
          <div class="flex items-center justify-between border-b border-white/8 px-5 py-4">
            <div>
              <p class="mb-1 text-[10px] uppercase tracking-[0.28em] text-[#C4A072]">Ubicación seleccionada</p>
              <p id="store-map-name" class="text-sm font-semibold text-white">{puntosVenta[0].nombre}</p>
            </div>
            <a
              id="store-map-external"
              href={'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent([puntosVenta[0].nombre, puntosVenta[0].direccion, puntosVenta[0].cp, puntosVenta[0].poblacion, 'España'].join(', '))}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-xs text-white/45 transition-colors hover:text-[#C4A072]"
            >
              Abrir Maps
              <ExternalLink size={14} stroke-width={1.6} aria-hidden="true" />
            </a>
          </div>
          <iframe
            id="store-map-frame"
            title={'Mapa de ' + puntosVenta[0].nombre}
            src={'https://www.google.com/maps?q=' + encodeURIComponent([puntosVenta[0].nombre, puntosVenta[0].direccion, puntosVenta[0].cp, puntosVenta[0].poblacion, 'España'].join(', ')) + '&output=embed'}
            class="h-[600px] w-full border-0 grayscale-[0.2]"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </aside>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('astro:page-load', () => {
      const frame = document.getElementById('store-map-frame') as HTMLIFrameElement | null;
      const name = document.getElementById('store-map-name');
      const external = document.getElementById('store-map-external') as HTMLAnchorElement | null;
      const postcodeSearch = document.getElementById('store-postcode-search') as HTMLInputElement | null;
      const searchMessage = document.getElementById('store-search-message');
      const addressLinks = document.querySelectorAll<HTMLAnchorElement>('[data-map-query]');
      if (!frame || !name || !external) return;

      const selectStore = (link: HTMLAnchorElement) => {
        const query = link.dataset.mapQuery;
        const storeName = link.dataset.mapName;
        if (!query || !storeName) return;

        frame.src = 'https://www.google.com/maps?q=' + encodeURIComponent(query) + '&output=embed';
        frame.title = 'Mapa de ' + storeName;
        name.textContent = storeName;
        external.href = link.href;

        document.querySelectorAll('[data-store-card]').forEach((card) => {
          card.classList.remove('is-active', 'border-[#C4A072]/45', 'bg-[#C4A072]/[0.045]');
          card.classList.add('border-white/7');
        });

        const card = link.closest('[data-store-card]');
        card?.classList.remove('border-white/7');
        card?.classList.add('is-active', 'border-[#C4A072]/45', 'bg-[#C4A072]/[0.045]');
      };

      addressLinks.forEach((link) => {
        link.addEventListener('click', (event) => {
          if (!window.matchMedia('(min-width: 1024px)').matches) return;

          event.preventDefault();
          selectStore(link);
        });
      });

      postcodeSearch?.addEventListener('input', () => {
        const value = postcodeSearch.value.replace(/\D/g, '').slice(0, 5);
        postcodeSearch.value = value;

        const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-store-card]'));
        searchMessage?.classList.add('hidden');

        if (value.length < 5) {
          const matches = cards.filter((card) => {
            const postcode = card.dataset.storePostcode ?? '';
            const isMatch = value === '' || postcode.startsWith(value);
            card.classList.toggle('hidden', !isMatch);
            return isMatch;
          });

          if (matches.length === 0 && value !== '' && searchMessage) {
            searchMessage.textContent = 'No encontramos una tienda en esa zona postal. Prueba con otro código o consulta el mapa.';
            searchMessage.classList.remove('hidden');
          }
          return;
        }

        const exactMatches = cards.filter((card) => card.dataset.storePostcode === value);
        if (exactMatches.length > 0) {
          cards.forEach((card) => card.classList.toggle('hidden', !exactMatches.includes(card)));
          const firstLink = exactMatches[0].querySelector<HTMLAnchorElement>('[data-map-query]');
          if (firstLink && window.matchMedia('(min-width: 1024px)').matches) selectStore(firstLink);
          return;
        }

        const provincePrefix = value.slice(0, 2);
        const sameProvince = cards
          .filter((card) => (card.dataset.storePostcode ?? '').startsWith(provincePrefix))
          .sort((a, b) => {
            const distanceA = Math.abs(Number(a.dataset.storePostcode) - Number(value));
            const distanceB = Math.abs(Number(b.dataset.storePostcode) - Number(value));
            return distanceA - distanceB;
          });

        if (sameProvince.length > 0) {
          const nearest = sameProvince[0];
          cards.forEach((card) => card.classList.toggle('hidden', card !== nearest));
          if (searchMessage) {
            searchMessage.textContent = 'No tenemos tienda exactamente en el código postal ' + value + '. Te mostramos la más cercana dentro de la misma zona postal.';
            searchMessage.classList.remove('hidden');
          }
          const nearestLink = nearest.querySelector<HTMLAnchorElement>('[data-map-query]');
          if (nearestLink && window.matchMedia('(min-width: 1024px)').matches) selectStore(nearestLink);
          return;
        }

        cards.forEach((card) => card.classList.add('hidden'));
        if (searchMessage) {
          searchMessage.textContent = 'No encontramos una tienda en esa provincia o zona postal. Prueba con otro código o consulta el mapa.';
          searchMessage.classList.remove('hidden');
        }
      });
    });
  </script>

  <!-- FOOTER -->
  <footer class="bg-[#0f0a08] border-t border-white/5 px-5 md:px-16 py-10 flex flex-col md:flex-row items-center md:items-center justify-between gap-4 text-center md:text-left">
    <div>
      <p class="text-sm font-semibold text-white mb-1">T3R · The Three Riders × Fundamental</p>
      <p class="text-xs text-white/40">Distribuido por Fundamental Bike Parts · Madrid, España</p>
    </div>
    <p class="text-xs text-white/20">© 2026 FUNDAMENTAL</p>
  </footer>

</Layout>
