---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Transfer Bike — Fundamental">

  <!-- NAV -->
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-16 py-6 bg-black/70 backdrop-blur-md">
    <a href="/" class="font-display uppercase text-xl tracking-[-0.03em] text-white" style="font-weight: 600;" transition:name="nav-logo">Fundamental Bike Parts</a>
    <nav class="flex gap-10">
      <a href="/marcas" class="text-base text-white/70 hover:text-white transition-colors">Marcas</a>
      <a href="/nosotros" class="text-base text-white/70 hover:text-white transition-colors">Nosotros</a>
      <a href="/contacto" class="text-base text-white/70 hover:text-white transition-colors">Contacto</a>
    </nav>
  </header>

  <!-- HERO -->
  <section class="relative h-screen bg-[#111] flex flex-col justify-end overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/catalogo_transferbike/bici_transferbike.jpeg');"></div>
    <div class="absolute inset-0" style="background: linear-gradient(to top, #0a0a0a 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0.1) 100%);"></div>

    <div class="relative z-20 px-16 pb-16">
      <img src="/logo_transfer.png" alt="Transfer Bike" class="h-8 w-auto mb-8 brightness-0 invert opacity-90" />
      <p class="text-xs text-white/50 tracking-[0.4em] uppercase mb-4 font-medium">Dirt Jump · Pump Track · Fundamental</p>
      <h1 class="text-7xl font-bold leading-none text-white mb-6 tracking-tight">
        Cuadros y bicis<br/>
        <span class="text-white/50">hechos para volar.</span>
      </h1>
      <a href="#kanaya" class="inline-flex items-center gap-2 text-sm text-white/70 hover:text-white transition-colors tracking-[0.1em] uppercase">
        Ver modelo Kanaya
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- INTRO -->
  <section class="bg-[#0a0a0a] px-16 py-20 border-b border-white/5">
    <div class="max-w-6xl mx-auto flex items-center justify-between gap-16">
      <div data-reveal class="max-w-xl">
        <p class="text-xs text-white/40 tracking-[0.3em] uppercase mb-4">La marca</p>
        <p class="text-white/70 text-lg leading-relaxed">
          Transfer Bike fabrica cuadros y bicicletas completas para dirt jump y pump track. Aluminio mecanizado, geometrías probadas en pista y un acabado raw que no esconde nada. Distribuimos su modelo Kanaya bajo solicitud.
        </p>
      </div>
      <div data-reveal data-delay="2" class="flex gap-12 shrink-0">
        <div class="text-center">
          <p class="text-3xl font-bold text-white">Al 6061</p>
          <p class="text-xs text-white/40 uppercase tracking-widest mt-1">Aluminio</p>
        </div>
        <div class="w-px bg-white/10"></div>
        <div class="text-center">
          <p class="text-3xl font-bold text-white">DJ/PT</p>
          <p class="text-xs text-white/40 uppercase tracking-widest mt-1">Disciplinas</p>
        </div>
        <div class="w-px bg-white/10"></div>
        <div class="text-center">
          <p class="text-3xl font-bold text-white">Raw</p>
          <p class="text-xs text-white/40 uppercase tracking-widest mt-1">Acabado</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCTOS -->
  <section id="kanaya" class="bg-[#0a0a0a] px-16 py-24">
    <div class="max-w-6xl mx-auto">

      <div class="mb-14 border-b border-white/10 pb-8 flex items-end justify-between">
        <div>
          <p data-reveal class="text-xs text-white/40 tracking-[0.35em] uppercase mb-3">Disponible bajo pedido</p>
          <h2 data-reveal data-delay="1" class="text-5xl font-bold text-white">Kanaya</h2>
        </div>
        <p data-reveal data-delay="2" class="text-sm text-white/40">2 referencias · Solicitar en Fundamental</p>
      </div>

      <!-- 2 productos lado a lado -->
      <div class="grid grid-cols-2 gap-6 mb-6">

        <!-- Bicicleta completa -->
        <a href="https://www.transferbikes.com/comprar" target="_blank" rel="noopener noreferrer"
          data-reveal class="group flex flex-col bg-[#111] overflow-hidden cursor-pointer">
          <div class="relative overflow-hidden" style="height: 360px;">
            <img src="/catalogo_transferbike/bici_transferbike.jpeg" alt="Bicicleta Kanaya completa"
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
          </div>
          <div class="p-7 flex flex-col flex-1 border-t border-white/5">
            <p class="text-xs text-white/40 tracking-[0.3em] uppercase mb-3">Bicicleta completa</p>
            <h3 class="text-2xl font-bold text-white mb-2">Kanaya</h3>
            <p class="text-white/50 text-sm mb-6">Lista para rodar · DJ / Pump Track</p>
            <div class="flex items-center justify-between mt-auto pt-5 border-t border-white/10">
              <p class="text-white text-xl font-semibold">699,00 €</p>
              <span class="text-xs text-white/50 group-hover:text-white transition-colors tracking-[0.2em] uppercase">
                Comprar →
              </span>
            </div>
          </div>
        </a>

        <!-- Cuadro solo -->
        <a href="https://www.transferbikes.com/comprar" target="_blank" rel="noopener noreferrer"
          data-reveal data-delay="1" class="group flex flex-col bg-[#111] overflow-hidden cursor-pointer">
          <div class="relative bg-white overflow-hidden" style="height: 360px;">
            <img src="/catalogo_transferbike/cuadro_kanaya.jpg" alt="Cuadro Kanaya"
              class="absolute inset-0 w-full h-full object-contain p-10 transition-transform duration-700 group-hover:scale-105" />
          </div>
          <div class="p-7 flex flex-col flex-1 border-t border-white/5">
            <p class="text-xs text-white/40 tracking-[0.3em] uppercase mb-3">Solo cuadro</p>
            <h3 class="text-2xl font-bold text-white mb-2">Kanaya</h3>
            <p class="text-white/50 text-sm mb-6">Aluminio 6061 · Raw · DJ / Pump Track</p>
            <div class="flex items-center justify-between mt-auto pt-5 border-t border-white/10">
              <p class="text-white text-xl font-semibold">299,00 €</p>
              <span class="text-xs text-white/50 group-hover:text-white transition-colors tracking-[0.2em] uppercase">
                Comprar →
              </span>
            </div>
          </div>
        </a>

      </div>

      <!-- Detalles fabricación -->
      <div class="grid grid-cols-3 gap-4">
        <div data-reveal class="relative bg-[#0d0d0d] aspect-video overflow-hidden col-span-2">
          <img src="/catalogo_transferbike/cuadro_kanaya_2.jpg" alt="Detalle vainas traseras"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 hover:scale-105" />
          <div class="absolute inset-0 bg-black/20"></div>
          <div class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/70 to-transparent">
            <p class="text-white/50 text-xs uppercase tracking-widest">Detalle · Vainas traseras</p>
          </div>
        </div>
        <div data-reveal data-delay="1" class="relative bg-[#0d0d0d] aspect-video overflow-hidden">
          <img src="/catalogo_transferbike/cuadro_kanaya_3.jpg" alt="Detalle head tube"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 hover:scale-105" />
          <div class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/70 to-transparent">
            <p class="text-white/50 text-xs uppercase tracking-widest">Detalle · Head tube</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- GEOMETRÍA -->
  <section class="bg-[#080808] px-16 py-24 border-t border-white/5">
    <div class="max-w-6xl mx-auto">

      <div class="mb-12">
        <p data-reveal class="text-xs text-white/40 tracking-[0.35em] uppercase mb-3">Especificaciones</p>
        <h2 data-reveal data-delay="1" class="text-4xl font-bold text-white">Geometría</h2>
      </div>

      <!-- Diagrama -->
      <div data-reveal class="bg-white rounded-sm overflow-hidden mb-10">
        <img src="/catalogo_transferbike/cuadro_bicicleta_kanaya.jpg" alt="Geometría Transfer Kanaya"
          class="w-full h-auto" />
      </div>

      <!-- Tabla de medidas -->
      <div data-reveal data-delay="1" class="grid grid-cols-4 gap-px bg-white/10">
        {[
          { label: 'Seat Tube', value: '310 mm' },
          { label: 'Seat Tube Angle', value: '67.9°' },
          { label: 'Head Tube Angle', value: '70°' },
          { label: 'Head Tube Length', value: '120 mm' },
          { label: 'Top Tube', value: '570 mm' },
          { label: 'Chain Stay', value: '390 mm' },
          { label: 'Fork Length', value: '120 mm' },
          { label: 'Reach', value: '587 mm' },
        ].map((spec) => (
          <div class="bg-[#0f0f0f] px-6 py-5">
            <p class="text-xs text-white/40 uppercase tracking-widest mb-2">{spec.label}</p>
            <p class="text-white font-semibold text-xl">{spec.value}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#0a0a0a] py-24 px-16 border-t border-white/5">
    <div class="max-w-6xl mx-auto flex items-center justify-between gap-16">
      <div data-reveal>
        <p class="text-xs text-white/40 tracking-[0.35em] uppercase mb-4">Solicitar</p>
        <h2 class="text-4xl font-bold text-white mb-4">Disponible bajo pedido.</h2>
        <p class="text-white/50 text-base leading-relaxed max-w-md">
          El cuadro y la bici completa Kanaya se gestionan a través de Fundamental. Escríbenos con tu referencia y te confirmamos disponibilidad y plazo.
        </p>
      </div>
      <div data-reveal data-delay="2" class="flex flex-col gap-3 shrink-0">
        <a href="https://www.transferbikes.com/comprar" target="_blank" rel="noopener noreferrer"
          class="bg-white text-black text-sm font-semibold px-10 py-4 hover:bg-white/90 transition-colors tracking-[0.08em] uppercase text-center">
          Solicitar referencia
        </a>
        <a href="/marcas"
          class="border border-white/20 text-white/60 text-sm px-10 py-4 hover:border-white/40 hover:text-white transition-colors tracking-[0.08em] uppercase text-center">
          ← Volver a marcas
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-black border-t border-white/5 px-16 py-10 flex items-center justify-between">
    <div>
      <p class="text-sm font-semibold text-white mb-1">Transfer Bike × Fundamental</p>
      <p class="text-xs text-white/40">Distribuido por Fundamental Bike Parts · Madrid, España</p>
    </div>
    <p class="text-xs text-white/20">© 2026 FUNDAMENTAL</p>
  </footer>

</Layout>
