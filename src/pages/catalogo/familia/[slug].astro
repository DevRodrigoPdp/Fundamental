---
import path from 'path';
import { existsSync } from 'fs';
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import BackToTop from '../../../components/BackToTop.astro';
import '../../../styles/global.css';
import { supabase } from '../../../lib/supabase';
import { SITE, absoluteUrl } from '../../../config/site';
import {
  catalogFamilies,
  productBelongsToFamily,
  type CatalogFamily,
} from '../../../data/catalog-families';

type FamilyProduct = {
  nombre: string;
  descripcion_corta: string | null;
  sku: string;
  categoria: string;
  subcategoria: string | null;
  imagen: string | null;
};

export async function getStaticPaths() {
  const existingImage = (relUrl: string | null) => {
    if (!relUrl) return null;
    const rel = relUrl.replace(/^\/+/, '');
    return existsSync(path.join(process.cwd(), 'public', rel)) ? `/${rel}` : null;
  };

  const { data: products } = await supabase
    .from('productos_t3r')
    .select('nombre, descripcion_corta, sku, categoria, subcategoria')
    .eq('activo', true);

  const skus = (products ?? []).map((product: any) => product.sku);
  const { data: images } = skus.length
    ? await supabase
        .from('imagenes_productos')
        .select('producto_sku, url')
        .in('producto_sku', skus)
        .eq('orden', 1)
    : { data: [] };

  const imageMap: Record<string, string | null> = {};
  (images ?? []).forEach((image: any) => {
    imageMap[image.producto_sku] = existingImage(image.url);
  });

  return catalogFamilies.map((family) => ({
    params: { slug: family.slug },
    props: {
      family,
      familyProducts: (products ?? [])
        .filter((product: any) => productBelongsToFamily(product, family))
        .map((product: any) => ({
          ...product,
          imagen: imageMap[product.sku] ?? null,
        }))
        .sort((a: any, b: any) => a.nombre.localeCompare(b.nombre, 'es', { sensitivity: 'base' })),
    },
  }));
}

const {
  family,
  familyProducts,
} = Astro.props as {
  family: CatalogFamily;
  familyProducts: FamilyProduct[];
};

const familyUrl = absoluteUrl(`/catalogo/familia/${family.slug}/`);
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: family.cat,
    description: family.description,
    url: familyUrl,
    isPartOf: { '@id': `${SITE.url}/#website` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'T3R', item: absoluteUrl('/t3r') },
      { '@type': 'ListItem', position: 3, name: family.cat, item: familyUrl },
    ],
  },
];
---

<Layout
  title={`${family.cat} | Catálogo T3R`}
  description={family.description}
  image={family.img}
  structuredData={schema}
>
  <Nav />
  <BackToTop />

  <main class="px-5 pb-28 pt-28 md:px-16 md:pt-36">
    <div class="mx-auto max-w-[1500px]">
      <nav class="mb-10 flex flex-wrap items-center gap-3 text-sm">
        <a href="/t3r#categorias" class="text-gray-400 transition-colors hover:text-black">Gama T3R</a>
        <span class="text-gray-300">/</span>
        <span class="text-gray-700">{family.cat}</span>
      </nav>

      <div class="grid items-start gap-12 lg:grid-cols-[320px_minmax(0,1fr)] xl:grid-cols-[380px_minmax(0,1fr)] xl:gap-20">
        <aside class="lg:sticky lg:top-28">
          <div class="mb-6 flex items-center gap-3">
            <span class="h-px w-7 bg-[#C4A072]"></span>
            <p class="text-[10px] uppercase tracking-[0.32em] text-[#C4A072]">{family.tag}</p>
          </div>

          <h1 class="text-[38px] font-bold leading-[0.95] tracking-tight md:text-[52px]">{family.cat}</h1>
          <p class="mt-7 text-base leading-relaxed text-gray-600">{family.description}</p>

          <ul class="mt-8 space-y-4 border-t border-gray-200 pt-7">
            {family.details.map((detail) => (
              <li class="flex gap-3 text-sm leading-relaxed text-gray-600">
                <span class="mt-[0.55rem] h-1.5 w-1.5 shrink-0 rounded-full bg-[#C4A072]"></span>
                <span>{detail}</span>
              </li>
            ))}
          </ul>

          <img
            src={family.img}
            alt=""
            class="mx-auto mt-8 h-44 w-44 object-contain"
          />
        </aside>

        <section>
          <div class="mb-7 flex items-end justify-between gap-5 border-b border-gray-200 pb-5">
            <div>
              <p class="mb-2 text-[10px] uppercase tracking-[0.25em] text-gray-400">Referencias disponibles</p>
              <h2 class="text-2xl font-bold">Todos los modelos</h2>
            </div>
            <p class="shrink-0 text-sm text-gray-400">
              {familyProducts.length} {familyProducts.length === 1 ? 'producto' : 'productos'}
            </p>
          </div>

          {familyProducts.length ? (
            <div class="grid grid-cols-1 gap-3 min-[460px]:grid-cols-2 xl:grid-cols-3">
              {familyProducts.map((product, index) => (
                <a
                  href={`/catalogo/${product.sku}`}
                  data-reveal
                  data-delay={String(index % 3)}
                  class="group flex flex-col border border-gray-200 bg-white transition-[border-color,box-shadow] duration-300 hover:border-gray-400 hover:shadow-[0_12px_34px_rgba(0,0,0,0.06)]"
                >
                  <div class="relative aspect-[4/3] overflow-hidden bg-white">
                    {product.imagen ? (
                      <img
                        src={product.imagen}
                        alt={product.nombre}
                        class="absolute inset-0 h-full w-full object-contain p-5 transition-transform duration-500 group-hover:scale-[1.035]"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 text-gray-300">
                        <img src="/logo_t3r.png" alt="T3R" class="w-16 opacity-25 grayscale" />
                        <span class="text-[9px] uppercase tracking-[0.2em]">Foto próximamente</span>
                      </div>
                    )}
                  </div>

                  <div class="flex flex-1 flex-col border-t border-gray-100 p-5">
                    <p class="mb-2 text-[9px] uppercase tracking-[0.2em] text-gray-400">
                      {product.subcategoria ?? product.categoria}
                    </p>
                    <h3 class="text-[15px] font-bold leading-snug transition-colors group-hover:text-[#6B8CAE]">
                      {product.nombre}
                    </h3>
                    {product.descripcion_corta && (
                      <p class="mt-3 line-clamp-2 text-xs leading-relaxed text-gray-500">
                        {product.descripcion_corta}
                      </p>
                    )}
                    <div class="mt-auto flex items-center justify-between gap-4 pt-5">
                      <span class="truncate text-[10px] text-gray-400">{product.sku}</span>
                      <span class="shrink-0 text-xs font-semibold">Ver →</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="border border-gray-200 px-6 py-16 text-center text-sm text-gray-400">
              Próximamente añadiremos referencias a esta familia.
            </div>
          )}
        </section>
      </div>
    </div>
  </main>
</Layout>
