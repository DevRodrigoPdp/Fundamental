---
import path from 'path';
import { existsSync } from 'fs';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import '../../styles/global.css';
import { supabase } from '../../lib/supabase';
import { SITE, absoluteUrl } from '../../config/site';

const CONTACT_EMAIL = 'info@fundamentalbikeparts.com';

export async function getStaticPaths() {
  const { data: products } = await supabase
    .from('productos_t3r')
    .select('sku')
    .eq('activo', true);

  return (products ?? []).map((p: any) => ({ params: { sku: p.sku } }));
}

const { sku } = Astro.params;

const { data: product } = await supabase
  .from('productos_t3r')
  .select('*')
  .eq('sku', sku)
  .single();

if (!product) {
  return Astro.redirect('/catalogo');
}

function existingImage(relUrl: string | null) {
  if (!relUrl) return null;
  const rel = relUrl.replace(/^\/+/, '');
  return existsSync(path.join(process.cwd(), 'public', rel)) ? `/${rel}` : null;
}

const { data: imagenesRaw } = await supabase
  .from('imagenes_productos')
  .select('url, orden')
  .eq('producto_sku', sku)
  .order('orden', { ascending: true });

const images: string[] = [];
(imagenesRaw ?? []).forEach((i: any) => {
  const img = existingImage(i.url);
  if (img) images.push(img);
});

const { data: subRaw } = await supabase
  .from('productos_t3r')
  .select('nombre, sku, subcategoria, categoria')
  .eq('subcategoria', product.subcategoria)
  .eq('activo', true)
  .neq('sku', sku)
  .limit(4);

let relatedRaw = subRaw ?? [];

if (relatedRaw.length < 4) {
  const { data: catRaw } = await supabase
    .from('productos_t3r')
    .select('nombre, sku, subcategoria, categoria')
    .eq('categoria', product.categoria)
    .eq('activo', true)
    .limit(12);
  const seen = new Set([sku, ...relatedRaw.map((p: any) => p.sku)]);
  const fill = (catRaw ?? []).filter((p: any) => !seen.has(p.sku));
  relatedRaw = [...relatedRaw, ...fill].slice(0, 4);
}

const relatedSkus = relatedRaw.map((p: any) => p.sku);
const { data: relatedImgsRaw } = relatedSkus.length > 0
  ? await supabase
      .from('imagenes_productos')
      .select('producto_sku, url')
      .in('producto_sku', relatedSkus)
      .eq('orden', 1)
  : { data: [] };

const relatedImgMap: Record<string, string | null> = {};
(relatedImgsRaw ?? []).forEach((i: any) => { relatedImgMap[i.producto_sku] = existingImage(i.url); });

const related = relatedRaw.map((p: any) => ({
  nombre: p.nombre,
  sku: p.sku,
  imagen: relatedImgMap[p.sku],
}));

const isDiskFamily = product.sku.startsWith('T3R-DISCO-6T-') || product.sku.startsWith('T3R-DISCO-CL-');
const diskVariants = isDiskFamily
  ? [product, ...(relatedRaw ?? [])]
      .map((variant: any) => ({
        sku: variant.sku,
        size: Number(variant.sku.match(/(\d+)$/)?.[1]),
      }))
      .filter((variant: any) => Number.isFinite(variant.size))
      .sort((a: any, b: any) => a.size - b.size)
  : [];

const especificaciones: Record<string, any> = product.especificaciones ?? {};
const cantidadStock: number | null = product.stock ?? null;
const stockLabel = cantidadStock === 0
  ? 'Agotado'
  : cantidadStock !== null && cantidadStock <= 10
    ? 'Pocas unidades en stock'
    : null;

function formatValue(v: any) {
  if (typeof v === 'boolean') return v ? 'Sí' : 'No';
  return String(v);
}
function formatKey(k: string) {
  return k.charAt(0).toUpperCase() + k.slice(1).replace(/_/g, ' ');
}

const mailtoHref = `mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent(`Solicitud T3R — ${product.nombre}`)}&body=${encodeURIComponent(
  `Hola,\n\nMe interesa el siguiente producto T3R:\n\nProducto: ${product.nombre}\nReferencia (SKU): ${product.sku}\nCategoría: ${product.categoria}${product.subcategoria ? ' / ' + product.subcategoria : ''}\n\nPor favor, indícame disponibilidad y precio.\n\nGracias.`
)}`;

const seoDescription = (
  product.descripcion_corta
  ?? product.descripcion
  ?? `${product.nombre} de T3R. Consulta características, medidas y disponibilidad en Fundamental Bike Parts.`
).replace(/\s+/g, ' ').trim().slice(0, 160);

const productUrl = absoluteUrl(`/catalogo/${product.sku}/`);
const productSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  '@id': `${productUrl}#product`,
  name: product.nombre,
  description: seoDescription,
  sku: product.sku,
  category: [product.categoria, product.subcategoria].filter(Boolean).join(' > '),
  url: productUrl,
  image: images.map((image) => absoluteUrl(image)),
  brand: {
    '@type': 'Brand',
    name: 'T3R',
  },
  manufacturer: {
    '@id': `${SITE.url}/#organization`,
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Catálogo T3R', item: absoluteUrl('/catalogo') },
    { '@type': 'ListItem', position: 3, name: product.nombre, item: productUrl },
  ],
};
---

<Layout
  title={`${product.nombre} | T3R Fundamental`}
  description={seoDescription}
  image={images[0] ?? '/logo_t3r.png'}
  type="product"
  structuredData={[productSchema, breadcrumbSchema]}
>

  <Nav />

  <section class="px-5 md:px-16 pb-24" style="padding-top: 110px;">

    <!-- Breadcrumb -->
    <div class="flex flex-wrap items-center gap-x-3 gap-y-2 mb-8 sm:mb-12">
      <a href="/catalogo" class="text-sm text-gray-400 hover:text-black transition-colors">Catálogo</a>
      <span class="text-gray-300 text-sm">/</span>
      <span class="text-sm text-gray-400">{product.categoria}</span>
      {product.subcategoria && (
        <span class="flex items-center gap-3">
          <span class="text-gray-300 text-sm">/</span>
          <span class="text-sm text-gray-600">{product.subcategoria}</span>
        </span>
      )}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-20">

      <!-- GALERÍA -->
      <div>
        <div class="relative overflow-hidden bg-[#f5f5f5] mb-4" style="aspect-ratio: 1;">
          {images[0] ? (
            <img id="main-image" src={images[0]} alt={product.nombre} class="absolute inset-0 w-full h-full object-contain bg-white p-6 md:p-10" />
          ) : (
            <div class="absolute inset-0 flex flex-col items-center justify-center gap-4 bg-white text-gray-300">
              <img src="/logo_t3r.png" alt="T3R" class="w-32 md:w-40 opacity-25 grayscale" />
              <p class="text-xs text-gray-300 tracking-[0.25em] uppercase">Foto proximamente</p>
            </div>
          )}
        </div>
        {images.length > 1 && (
          <div class="flex gap-3">
            {images.map((img, i) => (
              <button
                type="button"
                data-thumb={img}
                class="thumb-btn relative overflow-hidden bg-[#f5f5f5] border border-gray-200 hover:border-black transition-colors cursor-pointer"
                style="width: 76px; height: 76px;"
              >
                <img src={img} alt={`${product.nombre} ${i + 1}`} class="absolute inset-0 w-full h-full object-contain bg-white p-2" />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- INFO -->
      <div>
        <p class="text-sm text-[#6B8CAE] tracking-[0.25em] uppercase mb-4">{product.subcategoria ?? product.categoria}</p>
        <h1 class="text-[28px] md:text-[40px] font-bold leading-tight mb-3">{product.nombre}</h1>
        <p class="text-sm text-gray-400 mb-8">REF. {product.sku}</p>
        {stockLabel && (
          <p class:list={[
            'mb-8 text-sm font-semibold uppercase tracking-[0.12em]',
            cantidadStock === 0 ? 'text-red-600' : 'text-amber-700',
          ]}>
            {stockLabel}
          </p>
        )}

        {diskVariants.length > 0 && (
          <div class="mb-8">
            <p class="text-[11px] text-gray-400 tracking-[0.2em] uppercase mb-3">Medida disponible</p>
            <div class="flex flex-wrap gap-2">
              {diskVariants.map((variant: any) => (
                <a
                  href={`/catalogo/${variant.sku}`}
                  aria-current={variant.sku === product.sku ? 'page' : undefined}
                  class:list={[
                    'min-w-20 border px-4 py-3 text-center text-sm font-semibold transition-colors',
                    variant.sku === product.sku
                      ? 'border-black bg-black text-white'
                      : 'border-gray-200 bg-white text-black hover:border-black',
                  ]}
                >
                  {variant.size} mm
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="flex items-center gap-4 mb-8">
          {product.precio ? (
            <span class="text-xl font-semibold">{Number(product.precio).toFixed(2)} €</span>
          ) : (
            <a href={mailtoHref} class="text-gray-500 text-sm underline hover:text-[#6B8CAE] transition-colors cursor-pointer">Consultar precio</a>
          )}
        </div>

        {product.descripcion && (
          <p class="text-gray-600 text-lg leading-relaxed mb-10 max-w-lg">{product.descripcion}</p>
        )}

        {Object.keys(especificaciones).length > 0 && (
          <div class="border-t border-gray-200 pt-8 mb-10">
            <p class="text-sm text-gray-400 tracking-[0.2em] uppercase mb-5">Especificaciones</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              {Object.entries(especificaciones).map(([k, v]) => (
                <div>
                  <p class="text-gray-400 text-[11px] uppercase tracking-widest mb-1">{formatKey(k)}</p>
                  <p class="text-black text-sm font-medium">{formatValue(v)}</p>
                </div>
              ))}
            </div>
          </div>
        )}

        <a
          href={mailtoHref}
          class="inline-flex items-center justify-center gap-3 bg-black text-white text-sm font-medium px-10 py-4 hover:bg-[#222] transition-colors w-full cursor-pointer"
        >
          Solicitar este producto
          <span>→</span>
        </a>
      </div>

    </div>
  </section>

  {!isDiskFamily && related.length > 0 && (
    <section class="bg-[#fafafa] px-5 md:px-16 py-20 border-t border-gray-100">
      <p class="text-sm text-[#6B8CAE] tracking-[0.25em] uppercase mb-3">También te puede interesar</p>
      <h2 class="text-2xl font-bold mb-10">{product.categoria}</h2>
      <div class="grid grid-cols-1 min-[390px]:grid-cols-2 md:grid-cols-4 gap-px bg-gray-200 border border-gray-200">
        {related.map((r) => (
          <a href={`/catalogo/${r.sku}`} class="group bg-white block cursor-pointer">
            <div class="relative overflow-hidden bg-white" style="aspect-ratio: 1;">
              {r.imagen ? (
                <img
                  src={r.imagen}
                  alt={r.nombre}
                  class="absolute inset-0 w-full h-full object-contain p-5 transition-transform duration-500 group-hover:scale-[1.02]"
                  loading="lazy"
                />
              ) : (
                <div class="absolute inset-0 flex flex-col items-center justify-center gap-2 bg-white text-gray-300">
                  <img src="/logo_t3r.png" alt="T3R" class="w-16 opacity-25 grayscale" loading="lazy" />
                  <span class="text-[9px] tracking-[0.2em] uppercase text-gray-300">Sin foto</span>
                </div>
              )}
            </div>
            <div class="p-5">
              <h3 class="text-sm font-medium group-hover:text-[#6B8CAE] transition-colors">{r.nombre}</h3>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- FOOTER -->
  <footer class="border-t border-gray-100 px-5 md:px-16 py-10 flex flex-col md:flex-row items-center md:items-start justify-between gap-4 text-center md:text-left">
    <div>
      <p class="text-base font-bold mb-2">T3R × Fundamental</p>
      <p class="text-sm text-gray-400 max-w-[240px] leading-relaxed">
        Distribuidora de componentes profesionales para ciclismo. Madrid, España.
      </p>
      <a href="/contacto" class="inline-block mt-3 text-sm text-[#6B8CAE] hover:underline">Contacto →</a>
    </div>
    <p class="text-sm text-gray-400">© 2026 FUNDAMENTAL</p>
  </footer>

  <script>
    document.addEventListener('astro:page-load', () => {
      const mainImage = document.getElementById('main-image');
      document.querySelectorAll('.thumb-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const src = btn.getAttribute('data-thumb');
          if (mainImage && src) mainImage.setAttribute('src', src);
        });
      });
    });
  </script>

</Layout>
