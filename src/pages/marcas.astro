---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const brands = [
  {
    name: 'T3R',
    logo: '/logo_t3r.png',
    description: 'Componentes profesionales de ciclismo. Minimal, preciso, duradero.',
    cta: 'Ver catálogo',
    href: '/catalogo',
  },
  {
    name: 'Whipp-Off',
    logo: '/logo_whipoff.png',
    description: 'Ropa de MTB para quienes rompen la línea recta.',
    cta: 'Descubrir',
    href: '/whipp-off',
  },
  {
    name: 'Transfer',
    logo: '/logo_transfer.png',
    description: 'Bicicletas y cuadros. Equipamiento esencial.',
    cta: 'Ver modelo',
    href: '/transfer',
  },
];
---

<Layout title="Marcas — Fundamental">

  <!-- NAV -->
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-16 py-6 bg-[#1A100C]/80 backdrop-blur-md">
    <a href="/" class="font-display uppercase text-xl tracking-[-0.03em] text-white" style="font-weight: 600;" transition:name="nav-logo">Fundamental Bike Parts</a>
    <nav class="flex gap-10">
      <a href="/marcas" class="text-base text-white font-medium">Marcas</a>
      <a href="/nosotros" class="text-base text-white/70 hover:text-white transition-colors">Nosotros</a>
      <a href="/contacto" class="text-base text-white/70 hover:text-white transition-colors">Contacto</a>
    </nav>
  </header>

  <!-- HERO TEXTO -->
  <section class="px-16 pt-36 pb-24">
    <p data-reveal class="text-sm text-[#6B8CAE] tracking-[0.3em] uppercase mb-6">
      Distribuidora · Fundamental
    </p>
    <h1 data-reveal data-delay="1" class="text-[72px] font-bold leading-tight mb-8 whitespace-nowrap">
      Nuestras marcas.
    </h1>
    <p data-reveal data-delay="2" class="text-lg text-[#6B8CAE] max-w-md leading-relaxed">
      Tres marcas seleccionadas. Cada una con su propio universo y catálogo bajo solicitud.
    </p>
  </section>

  <!-- MARCAS GRID -->
  <section class="px-16 pb-36">
    <div class="grid grid-cols-3 border-t border-gray-200">
      {brands.map((brand, i) => (
        <div
          data-reveal
          data-delay={String(i + 1)}
          class={`group pt-14 pb-20 flex flex-col gap-7 transition-colors duration-300 hover:bg-[#F8F7F5] ${i < brands.length - 1 ? 'border-r border-gray-200' : ''} px-10`}
        >
          {brand.logo ? (
            <img src={brand.logo} alt={brand.name} class="h-60 w-auto object-contain" />
          ) : (
            <h2 class="text-[48px] font-bold leading-none">{brand.name}</h2>
          )}
          <p class="text-lg text-[#6B8CAE] leading-relaxed max-w-[280px]">
            {brand.description}
          </p>
          <a
            href={brand.href}
            class="text-base font-medium mt-auto inline-flex items-center gap-1"
          >
            {brand.cta}
            <span class="inline-block transition-transform duration-200 group-hover:translate-x-1">→</span>
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-gray-100 px-16 py-10 flex items-start justify-between">
    <div>
      <p class="text-base font-bold mb-2">T3R Fundamental</p>
      <p class="text-sm text-gray-400 max-w-[240px] leading-relaxed">
        Distribuidora de componentes profesionales para ciclismo. Madrid, España.
      </p>
    </div>
    <p class="text-sm text-gray-400">© 2026 FUNDAMENTAL</p>
  </footer>

</Layout>
