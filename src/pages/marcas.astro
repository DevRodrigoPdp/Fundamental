---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import '../styles/global.css';

const brands = [
  {
    name: 'T3R',
    logo: '/logo_t3r.png',
    description: 'Componentes profesionales de ciclismo. Minimal, preciso, duradero.',
    cta: 'Ver marca',
    href: '/t3r',
  },
  {
    name: 'Whipp-Off',
    logo: '/logo_whipoff.png',
    description: 'Ropa de MTB para quienes rompen la línea recta.',
    cta: 'Descubrir',
    href: '/whipp-off',
  },
  {
    name: 'Transfer',
    logo: '/logo_transfer.png',
    description: 'Bicicletas y cuadros. Equipamiento esencial.',
    cta: 'Ver modelo',
    href: '/transfer',
  },
];
---

<Layout title="Marcas — Fundamental">

  <Nav active="marcas" />

  <!-- HERO TEXTO -->
  <section class="px-5 md:px-16 pt-32 md:pt-36 pb-16 md:pb-24">
    <p data-reveal class="text-sm text-[#6B8CAE] tracking-[0.3em] uppercase mb-6">
      Distribuidora · Fundamental
    </p>
    <h1 data-reveal data-delay="1" class="text-[44px] md:text-[72px] font-bold leading-tight mb-8">
      Nuestras marcas.
    </h1>
    <p data-reveal data-delay="2" class="text-lg text-[#6B8CAE] max-w-md leading-relaxed">
      Tres marcas seleccionadas. Cada una con su propio universo y catálogo bajo solicitud.
    </p>
  </section>

  <!-- MARCAS GRID -->
  <section class="px-5 md:px-16 pb-20 md:pb-36">
    <div class="grid grid-cols-1 md:grid-cols-3 border-t border-gray-200">
      {brands.map((brand, i) => (
        <div
          data-reveal
          data-delay={String(i + 1)}
          class={`group pt-10 md:pt-14 pb-12 md:pb-20 flex flex-col gap-7 transition-colors duration-300 hover:bg-[#F8F7F5] border-b md:border-b-0 border-gray-200 ${i < brands.length - 1 ? 'md:border-r' : ''} px-2 md:px-10`}
        >
          <a
            href={brand.href}
            aria-label={'Ir a la página de ' + brand.name}
            class="flex w-full justify-center focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#6B8CAE]"
          >
            {brand.logo ? (
              <img
                src={brand.logo}
                alt={brand.name}
                class="h-32 w-auto object-contain transition-transform duration-500 group-hover:scale-[1.03] md:h-60"
              />
            ) : (
              <h2 class="text-[48px] font-bold leading-none">{brand.name}</h2>
            )}
          </a>
          <p class="text-lg text-[#6B8CAE] leading-relaxed max-w-[280px]">
            {brand.description}
          </p>
          <a
            href={brand.href}
            class="text-base font-medium mt-auto inline-flex items-center gap-1"
          >
            {brand.cta}
            <span class="inline-block transition-transform duration-200 group-hover:translate-x-1">→</span>
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-gray-100 px-5 md:px-16 py-10 flex flex-col md:flex-row items-center md:items-start justify-between gap-4 text-center md:text-left">
    <div>
      <p class="text-base font-bold mb-2">T3R Fundamental</p>
      <p class="text-sm text-gray-400 max-w-[240px] leading-relaxed">
        Distribuidora de componentes profesionales para ciclismo. Madrid, España.
      </p>
    </div>
    <p class="text-sm text-gray-400">© 2026 FUNDAMENTAL</p>
  </footer>

</Layout>

