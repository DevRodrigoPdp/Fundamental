---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { supabase } from '../../lib/supabase';

const CONTACT_EMAIL = 'pedidos@fundamentalbikeparts.com'; // TODO: cambiar al email real

type CategoryInfo = {
  name: string;
  refs: string;
  description: string;
  supabaseKey: string;
  images: string[];
};

const categoryMap: Record<string, CategoryInfo> = {
  'discos-de-freno': {
    name: 'Discos de freno',
    refs: '+29',
    description: 'Discos de freno para MTB, enduro y carretera. Center lock y tornillo. Compatibles con los principales sistemas del mercado.',
    supabaseKey: 'disco',
    images: [
      '/catalogo_t3r/discos_freno/discos_freno_center_lock_1.jpg',
      '/catalogo_t3r/discos_freno/discos_freno_center_lock_2.jpg',
      '/catalogo_t3r/discos_freno/discos_freno_tornillos_1.jpg',
    ],
  },
  'pastillas-de-freno': {
    name: 'Pastillas de freno',
    refs: '+50',
    description: 'Pastillas orgánicas y metálicas para los principales sistemas de freno del mercado. Compatibilidad garantizada.',
    supabaseKey: 'pastilla',
    images: [
      '/catalogo_t3r/pastillas_freno/pastillas_freno_1.jpg',
      '/catalogo_t3r/pastillas_freno/pastillas_freno_2.jpg',
      '/catalogo_t3r/pastillas_freno/pastillas_freno_3.jpg',
    ],
  },
  'pedales-plataforma': {
    name: 'Pedales plataforma',
    refs: '9',
    description: 'Plataformas de aluminio para MTB, trail y enduro. Gran superficie de apoyo y pines intercambiables.',
    supabaseKey: 'plataforma',
    images: [
      '/catalogo_t3r/pedal_plataforma/pedal_plataforma_1.jpg',
      '/catalogo_t3r/pedal_plataforma/pedal_plataforma_2.jpg',
      '/catalogo_t3r/pedal_plataforma/pedal_plataforma_3.jpg',
    ],
  },
  'pedales-automaticos': {
    name: 'Pedales automáticos',
    refs: '9',
    description: 'Pedales clipless para XCO, AM y e-Bike. Compatibles con cala SPD. Salida regulable.',
    supabaseKey: 'autom',
    images: [
      '/catalogo_t3r/pedal_automatico/pedal_automatico_1.jpg',
      '/catalogo_t3r/pedal_automatico/pedal_automatico_2.jpg',
      '/catalogo_t3r/pedal_automatico/pedal_automatico_3.jpg',
    ],
  },
  'pedales-carretera': {
    name: 'Pedales carretera',
    refs: '6',
    description: 'Pedales automáticos para carretera y cicloturismo. Sistema SPD-SL compatible. Cuerpo de aluminio.',
    supabaseKey: 'carretera',
    images: [
      '/catalogo_t3r/pedal_carretera/pedal_carretera_1.jpg',
      '/catalogo_t3r/pedal_carretera/pedal_carretera_2.jpg',
      '/catalogo_t3r/pedal_carretera/pedal_carretera_3.jpg',
    ],
  },
  'pedalier-bb': {
    name: 'Pedalier / BB',
    refs: '14',
    description: 'Ejes de pedalier para BSA, PF30, BB86 y más estándares. Materiales de calidad probados en competición.',
    supabaseKey: 'pedalier',
    images: [
      '/catalogo_t3r/pedalier_1/pedalier_1_1.jpg',
      '/catalogo_t3r/pedalier_1/pedalier_1_2.jpg',
      '/catalogo_t3r/pedalier_2/pedalier_2_1.jpg',
    ],
  },
  'punos': {
    name: 'Puños',
    refs: '4',
    description: 'Puños de silicona y ergonómicos para MTB y carretera. Una y dos arandelas de fijación.',
    supabaseKey: 'puño',
    images: [
      '/catalogo_t3r/punos/puno_arandelas_ergonomicos.jpg',
      '/catalogo_t3r/punos/puno_fijacion_una_arandela.jpg',
      '/catalogo_t3r/punos/puno_silicona.jpg',
    ],
  },
  'valvulas-tubeless': {
    name: 'Válvulas tubeless',
    refs: '5',
    description: 'Válvulas tubeless de aluminio anodizado. Compatibles con todos los sistemas de montaje tubeless del mercado.',
    supabaseKey: 'válvula',
    images: [
      '/catalogo_t3r/valvula_tubeless/valvula_tubeless_1.jpg',
      '/catalogo_t3r/valvula_tubeless/valvula_tubeless_2.jpg',
      '/catalogo_t3r/valvula_tubeless/valvula_tubeless_3.jpg',
    ],
  },
};

const { slug } = Astro.params;
const category = categoryMap[slug as string];

if (!category) {
  return Astro.redirect('/t3r');
}

// Buscar productos en Supabase por categoría
const { data: products } = await supabase
  .from('productos_t3r')
  .select('nombre, categoria, descripcion_corta, sku')
  .eq('activo', true)
  .ilike('categoria', `%${category.supabaseKey}%`);

const skus = (products ?? []).map((p: any) => p.sku);

const { data: imagenes } = skus.length > 0
  ? await supabase
      .from('imagenes_productos')
      .select('producto_sku, url, orden')
      .in('producto_sku', skus)
      .eq('orden', 1)
  : { data: [] };

const imgMap: Record<string, string> = {};
(imagenes ?? []).forEach((i: any) => { imgMap[i.producto_sku] = i.url; });

const formatted = (products ?? []).map((p: any) => ({
  nombre: p.nombre,
  categoria: p.categoria,
  descripcion: p.descripcion_corta,
  sku: p.sku,
  imagen: imgMap[p.sku] ? `/${imgMap[p.sku]}` : category.images[0],
}));

function mailtoLink(product: { nombre: string; sku: string; categoria: string }) {
  const subject = encodeURIComponent(`Solicitud T3R — ${product.nombre}`);
  const body = encodeURIComponent(
    `Hola,\n\nMe interesa el siguiente producto T3R:\n\nProducto: ${product.nombre}\nReferencia (SKU): ${product.sku}\nCategoría: ${product.categoria}\n\nPor favor, indícame disponibilidad, stock y condiciones de pedido.\n\nGracias.`
  );
  return `mailto:${CONTACT_EMAIL}?subject=${subject}&body=${body}`;
}
---

<Layout title={`${category.name} — T3R · Fundamental`}>

  <style is:global>
    html { scroll-behavior: smooth; }
  </style>

  <!-- NAV -->
  <header class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-16 py-6 bg-[#1A100C]/80 backdrop-blur-md">
    <a href="/" class="font-display uppercase text-xl tracking-[-0.03em] text-white" style="font-weight: 600;" transition:name="nav-logo">Fundamental Bike Parts</a>
    <nav class="flex gap-10">
      <a href="/nosotros" class="text-base text-white/70 hover:text-white transition-colors">Nosotros</a>
      <a href="/contacto" class="text-base text-white/70 hover:text-white transition-colors">Contacto</a>
    </nav>
  </header>

  <!-- HEADER CATEGORÍA -->
  <section class="bg-[#1A100C] pt-32 pb-16 px-16 border-b border-white/5">
    <div class="max-w-6xl mx-auto">
      <!-- Breadcrumb -->
      <div class="flex items-center gap-3 mb-10">
        <a href="/t3r" class="text-xs text-white/40 hover:text-[#C4A072] transition-colors tracking-[0.2em] uppercase">T3R</a>
        <span class="text-white/20 text-xs">›</span>
        <span class="text-xs text-white/60 tracking-[0.2em] uppercase">{category.name}</span>
      </div>

      <div class="flex items-end justify-between gap-16">
        <div data-reveal>
          <p class="text-xs text-[#C4A072] tracking-[0.4em] uppercase mb-4">{category.refs} referencias</p>
          <h1 class="text-[64px] font-bold text-white leading-[0.9] tracking-tight mb-6">{category.name}</h1>
          <p class="text-white/55 text-lg leading-relaxed max-w-xl">{category.description}</p>
        </div>
        <!-- Minigalería de muestra -->
        <div data-reveal data-delay="2" class="flex gap-2 shrink-0">
          {category.images.slice(0, 3).map((img, i) => (
            <div class="relative overflow-hidden bg-white/5" style="width: 90px; height: 90px;">
              <img src={img} alt={category.name} class="w-full h-full object-cover opacity-70" />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- GRID PRODUCTOS -->
  <section class="bg-[#111] px-16 py-16">
    <div class="max-w-6xl mx-auto">

      {formatted.length > 0 ? (
        <div class="grid grid-cols-3 gap-px bg-white/5">
          {formatted.map((p, i) => (
            <div data-reveal data-delay={String(i % 3)} class="group bg-[#111] flex flex-col">
              <!-- Imagen producto -->
              <div class="relative overflow-hidden bg-[#1a1a1a]" style="height: 260px;">
                <img
                  src={p.imagen}
                  alt={p.nombre}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              <!-- Info -->
              <div class="p-7 flex flex-col flex-1 border-t border-white/5">
                <p class="text-[10px] text-[#C4A072] tracking-[0.3em] uppercase mb-3">{p.sku}</p>
                <h3 class="text-white font-semibold text-lg leading-snug mb-3 flex-1">{p.nombre}</h3>
                {p.descripcion && (
                  <p class="text-white/45 text-sm leading-relaxed mb-5">{p.descripcion}</p>
                )}
                <a
                  href={mailtoLink(p)}
                  class="inline-flex items-center justify-between w-full mt-auto pt-5 border-t border-white/10 group/btn cursor-pointer"
                >
                  <span class="text-xs text-white/50 group-hover/btn:text-white transition-colors tracking-[0.15em] uppercase">Solicitar este producto</span>
                  <span class="text-[#C4A072] text-sm group-hover/btn:translate-x-1 transition-transform duration-200">→</span>
                </a>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <!-- Estado vacío: no hay productos en Supabase para esta categoría todavía -->
        <div class="text-center py-24 border border-white/5">
          <p class="text-xs text-[#C4A072] tracking-[0.35em] uppercase mb-4">Catálogo en preparación</p>
          <p class="text-white/60 text-lg mb-8">Las referencias de esta categoría estarán disponibles próximamente.</p>
          <p class="text-white/30 text-sm mb-10">Mientras tanto, puedes contactarnos directamente para consultar disponibilidad.</p>
          <a
            href={`mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent(`Consulta categoría T3R — ${category.name}`)}&body=${encodeURIComponent(`Hola,\n\nMe interesa información sobre la categoría ${category.name} de T3R.\n\nPor favor, indícame qué referencias tenéis disponibles y condiciones de pedido.\n\nGracias.`)}`}
            class="inline-flex items-center gap-3 bg-[#C4A072] text-[#1A100C] text-sm font-bold px-10 py-4 hover:bg-[#D4B280] transition-colors tracking-[0.1em] uppercase cursor-pointer"
          >
            Consultar disponibilidad
            <span>→</span>
          </a>
        </div>
      )}

    </div>
  </section>

  <!-- CTA CONTACTO -->
  <section class="bg-[#0f0e0c] px-16 py-20 border-t border-white/5">
    <div class="max-w-6xl mx-auto flex items-center justify-between gap-16">
      <div data-reveal>
        <p class="text-xs text-[#C4A072] tracking-[0.35em] uppercase mb-4">Solicitar referencia</p>
        <h2 class="text-3xl font-bold text-white mb-3">¿No encuentras lo que buscas?</h2>
        <p class="text-white/50 text-base leading-relaxed max-w-md">
          Consúltanos cualquier referencia T3R. Gestionamos pedidos bajo solicitud con disponibilidad y plazo confirmados.
        </p>
      </div>
      <div data-reveal data-delay="2" class="flex flex-col gap-3 shrink-0">
        <a
          href={`mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent(`Consulta catálogo T3R — ${category.name}`)}`}
          class="bg-[#C4A072] text-[#1A100C] text-sm font-bold px-10 py-4 hover:bg-[#D4B280] transition-colors tracking-[0.1em] uppercase text-center cursor-pointer"
        >
          Enviar consulta
        </a>
        <a href="/t3r" class="border border-white/15 text-white/50 text-sm px-10 py-4 hover:border-white/30 hover:text-white transition-colors tracking-[0.08em] uppercase text-center">
          ← Volver a T3R
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-[#0f0a08] border-t border-white/5 px-16 py-10 flex items-center justify-between">
    <div>
      <p class="text-sm font-semibold text-white mb-1">T3R · The Three Riders × Fundamental</p>
      <p class="text-xs text-white/40">Distribuido por Fundamental Bike Parts · Madrid, España</p>
    </div>
    <p class="text-xs text-white/20">© 2026 FUNDAMENTAL</p>
  </footer>

</Layout>
