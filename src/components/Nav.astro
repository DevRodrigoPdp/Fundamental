---
type NavKey = 't3r' | 'catalogo' | 'marcas' | 'puntosVenta' | 'nosotros' | 'contacto';

interface Props {
  active?: NavKey;
  bgClass?: string;
}

const { active, bgClass = 'bg-[#0b0908]/95' } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const links: Array<{
  href: string;
  label: string;
  eyebrow: string;
  key: NavKey;
  flagship?: boolean;
}> = [
  { href: '/t3r', label: 'T3R Components', eyebrow: 'Marca principal', key: 't3r', flagship: true },
  { href: '/catalogo', label: 'Catálogo', eyebrow: 'Gama completa', key: 'catalogo' },
  { href: '/marcas', label: 'Marcas asociadas', eyebrow: 'T3R · Transfer · Whipp-Off', key: 'marcas' },
  { href: '/puntos-de-venta', label: 'Puntos de venta', eyebrow: 'Dónde encontrarnos', key: 'puntosVenta' },
  { href: '/nosotros', label: 'Nosotros', eyebrow: 'Fundamental Bike Parts', key: 'nosotros' },
  { href: '/contacto', label: 'Contacto', eyebrow: 'Consultas y pedidos', key: 'contacto' },
];

function isActive(href: string, key: NavKey) {
  return active === key || currentPath === href || currentPath.startsWith(href + '/');
}
---

<header
  class={`fixed inset-x-0 top-0 z-50 border-b border-white/8 ${bgClass} px-4 py-4 text-white shadow-[0_18px_60px_rgba(0,0,0,0.2)] backdrop-blur-xl backdrop-saturate-150 sm:px-5 sm:py-5 md:px-10 lg:px-14`}
>
  <div class="mx-auto grid max-w-7xl grid-cols-[auto_1fr] items-center gap-5 lg:flex lg:justify-between">
    <!-- Mobile trigger -->
    <button
      id="nav-toggle"
      type="button"
      class="relative z-50 inline-flex h-11 w-11 items-center justify-center text-white/80 transition-colors hover:text-white lg:hidden"
      aria-label="Abrir menú"
      aria-controls="nav-mobile-menu"
      aria-expanded="false"
    >
      <svg id="nav-icon-open" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.7" aria-hidden="true">
        <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
      </svg>
      <svg id="nav-icon-close" class="hidden h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.7" aria-hidden="true">
        <path stroke-linecap="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Desktop master menu -->
    <div class="nav-master-trigger relative hidden h-8 items-center lg:flex">
      <button
        id="nav-desktop-toggle"
        type="button"
        class="group inline-flex h-8 items-center gap-3 text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-white/72 transition-colors duration-300 hover:text-white"
        aria-haspopup="true"
        aria-expanded="false"
      >
        <span class="flex w-5 flex-col gap-[4px]" aria-hidden="true">
          <span class="h-px w-5 bg-current transition-transform duration-300 group-hover:translate-x-1"></span>
          <span class="h-px w-3 bg-[#C5A880] transition-[width] duration-300 group-hover:w-5"></span>
        </span>
        EXPLORAR
        <svg class="nav-master-chevron h-3 w-3 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="m7 10 5 5 5-5" />
        </svg>
      </button>

      <div class="nav-master-menu fixed inset-x-0 top-[72px] border-y border-white/8 bg-[#0c0b09]/98 text-white shadow-[0_35px_90px_rgba(0,0,0,0.52)] backdrop-blur-xl">
        <div class="mx-auto grid min-h-[540px] max-w-7xl grid-cols-[minmax(0,1.15fr)_minmax(420px,0.85fr)]">
          <nav class="p-10 xl:p-12" aria-label="Menú principal">
            <div class="mb-8 flex items-center justify-between border-b border-white/10 pb-5">
              <p class="text-[10px] uppercase tracking-[0.34em] text-[#C5A880]">Navegación Fundamental</p>
              <span class="text-[10px] uppercase tracking-[0.24em] text-white/25">Madrid · España</span>
            </div>

            <div>
              {
                links.map((link, index) => (
                  <a
                    href={link.href}
                    class:list={[
                      'group/menu-link grid grid-cols-[42px_1fr_auto] items-center border-b border-white/8 py-4 transition-colors duration-300 hover:border-[#C5A880]/35',
                      isActive(link.href, link.key) ? 'text-white' : 'text-white/62 hover:text-white',
                    ]}
                    aria-current={isActive(link.href, link.key) ? 'page' : undefined}
                  >
                    <span class="font-display text-[10px] font-bold tracking-[0.2em] text-white/22">
                      {String(index + 1).padStart(2, '0')}
                    </span>
                    <span>
                      <span class:list={['block text-2xl font-semibold tracking-[-0.035em] xl:text-3xl', link.flagship && 'text-[#C5A880]']}>
                        {link.label}
                      </span>
                      <span class="mt-1 block text-[9px] uppercase tracking-[0.24em] text-white/27">{link.eyebrow}</span>
                    </span>
                    <span class="-translate-x-2 text-xl font-light opacity-0 transition-all duration-300 group-hover/menu-link:translate-x-0 group-hover/menu-link:opacity-60">→</span>
                  </a>
                ))
              }
            </div>
          </nav>

          <a href="/t3r" class="group/feature relative overflow-hidden border-l border-white/8">
            <img
              src="/catalogo_t3r/combos/combos_3.jpg"
              alt="T3R Bike Components"
              class="absolute inset-0 h-full w-full object-cover saturate-[0.75] transition-transform duration-1000 group-hover/feature:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/25 to-black/15"></div>
            <div class="absolute inset-x-0 top-0 flex items-center justify-between p-8">
              <span class="text-[9px] font-bold uppercase tracking-[0.3em] text-[#C5A880]">Flagship</span>
              <span class="text-[9px] uppercase tracking-[0.26em] text-white/38">T3R / 2026</span>
            </div>
            <div class="absolute inset-x-0 bottom-0 p-9">
              <img src="/logo_blanco_t3r.png" alt="T3R" class="mb-7 h-10 w-auto" />
              <p class="max-w-md text-3xl font-semibold leading-tight tracking-tight">Componentes fundamentales para cuando el terreno exige más.</p>
              <span class="mt-7 inline-flex items-center gap-3 text-[10px] font-semibold uppercase tracking-[0.22em] text-[#C5A880]">
                Conocer la marca <span>→</span>
              </span>
            </div>
          </a>
        </div>
      </div>
    </div>

    <!-- Brand / home -->
    <a
      href="/"
      class="relative z-50 inline-flex h-8 w-fit max-w-full items-center gap-1.5 justify-self-end font-display text-[0.78rem] font-semibold uppercase leading-none tracking-[-0.045em] text-white transition-opacity duration-300 hover:opacity-75 sm:gap-2 sm:text-sm lg:text-xl lg:font-bold"
      aria-label="Fundamental Bike Parts - Inicio"
    >
      <span>Fundamental</span><span class="hidden sm:inline">Bike Parts</span>
    </a>
  </div>
</header>

<!-- Mobile overlay -->
<div
  id="nav-mobile-menu"
  class="pointer-events-none fixed inset-0 z-40 translate-y-[-10px] overflow-y-auto overscroll-contain bg-[#0b0908] px-5 pb-[max(2.5rem,env(safe-area-inset-bottom))] pt-24 opacity-0 transition-[opacity,transform] duration-300 ease-out sm:px-7 sm:pt-28 lg:hidden"
  aria-hidden="true"
  inert
>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(197,168,128,0.16),transparent_34%)]"></div>
  <nav class="relative mx-auto flex max-w-md flex-col" aria-label="Navegación móvil">
    {
      links.map((link, index) => (
        <a
          href={link.href}
          data-menu-link
          class:list={[
            'nav-menu-link grid grid-cols-[34px_1fr_auto] items-center border-b border-white/8 py-5 uppercase transition-colors',
            link.flagship ? 'text-[#C5A880]' : 'text-white/68 hover:text-white',
          ]}
          aria-current={isActive(link.href, link.key) ? 'page' : undefined}
        >
          <span class="font-display text-[9px] tracking-[0.18em] text-white/22">{String(index + 1).padStart(2, '0')}</span>
          <span class="text-xl font-medium tracking-[-0.025em]">{link.label}</span>
          <span class="text-base font-light opacity-35">↗</span>
        </a>
      ))
    }
  </nav>
  <p class="nav-menu-link relative mx-auto mt-10 max-w-md text-sm leading-relaxed text-white/38">
    Distribución especializada de componentes, bicicletas y equipamiento.
  </p>
</div>

<style>
  .nav-master-trigger::after {
    content: '';
    position: absolute;
    top: 100%;
    left: -22px;
    right: -22px;
    height: 24px;
  }

  .nav-master-menu {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(-10px);
    transition:
      opacity 220ms ease,
      visibility 220ms ease,
      transform 340ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-master-trigger:hover .nav-master-menu,
  .nav-master-trigger:focus-within .nav-master-menu,
  .nav-master-trigger.is-open .nav-master-menu,
  .nav-master-menu:hover {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .nav-master-trigger:hover .nav-master-chevron,
  .nav-master-trigger:focus-within .nav-master-chevron,
  .nav-master-trigger.is-open .nav-master-chevron {
    transform: rotate(180deg);
  }

  .nav-menu-link {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.28s ease-out, transform 0.28s ease-out, color 0.2s;
  }

  #nav-mobile-menu.is-open .nav-menu-link {
    opacity: 1;
    transform: translateY(0);
  }

  #nav-mobile-menu.is-open .nav-menu-link:nth-child(1) { transition-delay: 0.04s; }
  #nav-mobile-menu.is-open .nav-menu-link:nth-child(2) { transition-delay: 0.08s; }
  #nav-mobile-menu.is-open .nav-menu-link:nth-child(3) { transition-delay: 0.12s; }
  #nav-mobile-menu.is-open .nav-menu-link:nth-child(4) { transition-delay: 0.16s; }
  #nav-mobile-menu.is-open .nav-menu-link:nth-child(5) { transition-delay: 0.2s; }
  #nav-mobile-menu.is-open .nav-menu-link:nth-child(6) { transition-delay: 0.24s; }

  @media (prefers-reduced-motion: reduce) {
    .nav-master-menu,
    #nav-mobile-menu,
    .nav-menu-link {
      transition: none !important;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById('nav-toggle');
    const mobileMenu = document.getElementById('nav-mobile-menu');
    const iconOpen = document.getElementById('nav-icon-open');
    const iconClose = document.getElementById('nav-icon-close');
    const desktopTrigger = document.querySelector('.nav-master-trigger');
    const desktopToggle = document.getElementById('nav-desktop-toggle');

    const closeDesktopMenu = () => {
      desktopTrigger?.classList.remove('is-open');
      desktopToggle?.setAttribute('aria-expanded', 'false');
    };

    desktopToggle?.addEventListener('click', (event) => {
      event.stopPropagation();
      const willOpen = !desktopTrigger?.classList.contains('is-open');
      desktopTrigger?.classList.toggle('is-open', willOpen);
      desktopToggle.setAttribute('aria-expanded', String(willOpen));
    });

    document.addEventListener('click', (event) => {
      if (desktopTrigger && !desktopTrigger.contains(event.target as Node)) closeDesktopMenu();
    });

    if (!toggle || !mobileMenu) return;

    const closeMobileMenu = () => {
      if (mobileMenu.contains(document.activeElement)) {
        toggle.focus({ preventScroll: true });
      }
      mobileMenu.classList.add('pointer-events-none', 'translate-y-[-10px]', 'opacity-0');
      mobileMenu.classList.remove('pointer-events-auto', 'translate-y-0', 'opacity-100', 'is-open');
      mobileMenu.setAttribute('inert', '');
      mobileMenu.setAttribute('aria-hidden', 'true');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Abrir menú');
      document.body.classList.remove('overflow-hidden');
    };

    const openMobileMenu = () => {
      mobileMenu.removeAttribute('inert');
      mobileMenu.classList.remove('pointer-events-none', 'translate-y-[-10px]', 'opacity-0');
      mobileMenu.classList.add('pointer-events-auto', 'translate-y-0', 'opacity-100', 'is-open');
      mobileMenu.setAttribute('aria-hidden', 'false');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Cerrar menú');
      document.body.classList.add('overflow-hidden');
    };

    toggle.addEventListener('click', () => {
      if (mobileMenu.classList.contains('is-open')) closeMobileMenu();
      else openMobileMenu();
    });

    mobileMenu.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMobileMenu));

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      closeDesktopMenu();
      if (mobileMenu.classList.contains('is-open')) {
        closeMobileMenu();
        toggle.focus();
      }
    });
  });
</script>
