---
interface Props {
  active?: 'marcas' | 'nosotros' | 'contacto';
  bgClass?: string;
}
const { active, bgClass = 'bg-[#1A100C]/80' } = Astro.props;

function linkClass(key: string) {
  return active === key
    ? 'text-base text-white font-medium'
    : 'text-base text-white/70 hover:text-white transition-colors';
}
---

<header class={`fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-6 md:px-16 py-5 md:py-6 ${bgClass} backdrop-blur-md`}>
  <a href="/" class="order-2 md:order-none font-display uppercase text-base md:text-xl tracking-[-0.03em] text-white" style="font-weight: 600;" transition:name="nav-logo">
    Fundamental Bike Parts
  </a>

  <!-- Desktop -->
  <nav class="hidden md:flex gap-10">
    <a href="/marcas" class={linkClass('marcas')}>Marcas</a>
    <a href="/nosotros" class={linkClass('nosotros')}>Nosotros</a>
    <a href="/contacto" class={linkClass('contacto')}>Contacto</a>
  </nav>

  <!-- Mobile hamburger -->
  <button id="nav-toggle" type="button" class="order-1 md:order-none md:hidden text-white p-2 -ml-2 cursor-pointer" aria-label="Abrir menú" aria-expanded="false">
    <svg id="nav-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
    <svg id="nav-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
</header>

<!-- Mobile menu panel -->
<div
  id="nav-mobile-menu"
  class="fixed inset-0 z-40 bg-[#1A100C] md:hidden flex flex-col items-center justify-center gap-8 opacity-0 scale-95 pointer-events-none transition-[opacity,transform] duration-300 ease-out"
>
  <a href="/marcas" data-menu-link class="nav-menu-link text-2xl text-white/80 hover:text-white transition-colors">Marcas</a>
  <a href="/nosotros" data-menu-link class="nav-menu-link text-2xl text-white/80 hover:text-white transition-colors">Nosotros</a>
  <a href="/contacto" data-menu-link class="nav-menu-link text-2xl text-white/80 hover:text-white transition-colors">Contacto</a>
</div>

<style>
  .nav-menu-link {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.25s ease-out, transform 0.25s ease-out, color 0.2s;
  }
  #nav-mobile-menu.is-open .nav-menu-link {
    opacity: 1;
    transform: translateY(0);
  }
  #nav-mobile-menu.is-open .nav-menu-link:nth-child(1) { transition-delay: 0.05s; }
  #nav-mobile-menu.is-open .nav-menu-link:nth-child(2) { transition-delay: 0.1s; }
  #nav-mobile-menu.is-open .nav-menu-link:nth-child(3) { transition-delay: 0.15s; }
  @media (prefers-reduced-motion: reduce) {
    #nav-mobile-menu, .nav-menu-link { transition: none !important; }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById('nav-toggle');
    const menu = document.getElementById('nav-mobile-menu');
    const iconOpen = document.getElementById('nav-icon-open');
    const iconClose = document.getElementById('nav-icon-close');
    if (!toggle || !menu) return;

    const openMenu = () => {
      menu.classList.remove('opacity-0', 'scale-95', 'pointer-events-none');
      menu.classList.add('opacity-100', 'scale-100', 'pointer-events-auto', 'is-open');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.classList.add('overflow-hidden');
    };

    const closeMenu = () => {
      menu.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
      menu.classList.remove('opacity-100', 'scale-100', 'pointer-events-auto', 'is-open');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('overflow-hidden');
    };

    toggle.addEventListener('click', () => {
      const isOpen = menu.classList.contains('is-open');
      if (isOpen) closeMenu(); else openMenu();
    });

    menu.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));
  });
</script>
