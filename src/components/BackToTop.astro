---
const label = Astro.props.label ?? 'Volver arriba';
---

<button
  id="back-to-top"
  type="button"
  aria-label={label}
  class="fixed bottom-[max(1rem,env(safe-area-inset-bottom))] right-4 z-40 flex h-11 w-11 translate-y-4 items-center justify-center rounded-full border border-black bg-black text-white opacity-0 shadow-lg shadow-black/25 transition-all duration-300 hover:-translate-y-0.5 hover:bg-[#6B8CAE] hover:border-[#6B8CAE] hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-black focus:ring-offset-2 pointer-events-none sm:bottom-6 sm:right-6 sm:h-12 sm:w-12"
>
  <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 19V5m0 0-6 6m6-6 6 6" />
  </svg>
</button>

<script>
  document.addEventListener('astro:page-load', () => {
    const button = document.getElementById('back-to-top');
    if (!button) return;

    const visibleClass = ['opacity-100', 'translate-y-0', 'pointer-events-auto'];
    const hiddenClass = ['opacity-0', 'translate-y-4', 'pointer-events-none'];

    const toggle = () => {
      const shouldShow = window.scrollY > 420;
      button.classList.toggle(visibleClass[0], shouldShow);
      button.classList.toggle(visibleClass[1], shouldShow);
      button.classList.toggle(visibleClass[2], shouldShow);
      button.classList.toggle(hiddenClass[0], !shouldShow);
      button.classList.toggle(hiddenClass[1], !shouldShow);
      button.classList.toggle(hiddenClass[2], !shouldShow);
    };

    button.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    window.addEventListener('scroll', toggle, { passive: true });
    toggle();
  });
</script>
